{
  "name": "Astropress",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "1.82"
    }
  },
  "postCreateCommand": "npm install -g bun@1.3.10 && bun install && npx playwright install --with-deps chromium",
  "forwardPorts": [4321, 4322],
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "astro-build.astro-vscode",
        "rust-lang.rust-analyzer"
      ]
    }
  }
}
