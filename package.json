{
  "name": "astropress-monorepo",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "bdd:lint": "bun run scripts/bdd-lint.ts",
    "bdd:test": "bun run scripts/bdd-test.ts",
    "audit:deps": "bun audit",
    "audit:security": "bun run scripts/security-audit.ts",
    "audit:arch": "bun run scripts/arch-lint.ts",
    "audit:arch:rust": "bun run scripts/rust-arch-lint.ts",
    "audit:bundle": "bun run scripts/bundle-audit.ts",
    "test": "bun run audit:arch && bun run audit:arch:rust && bun run bdd:lint && bun run bdd:test && bun run --filter astropress test",
    "test:coverage": "bun run --filter astropress test:coverage",
    "test:acceptance": "bun run scripts/run-playwright.ts --project=example-a11y --project=admin-harness-a11y --project=admin-harness-mobile --project=admin-harness-mobile-iphonese --project=admin-harness-mobile-galaxys5 --project=admin-harness-a11y-interactions",
    "test:accessibility": "bun run --filter astropress-example-gh-pages build && bun run scripts/accessibility-audit.ts examples/github-pages/dist",
    "test:accessibility:browser": "bun run scripts/run-playwright.ts --project=example-a11y",
    "test:accessibility:admin-harness": "bun run scripts/run-playwright.ts --project=admin-harness-a11y",
    "test:admin-harness": "bun run --filter astropress-example-admin-harness check",
    "test:cli": "source \"$HOME/.cargo/env\" && cargo test",
    "test:example": "bun run --filter astropress-example-gh-pages check",
    "test:static-site": "bun run --filter astropress-example-gh-pages build && bun run scripts/static-site-audit.ts examples/github-pages/dist",
    "dev:example": "bun run --filter astropress-example-gh-pages dev",
    "audit:carbon": "bunx size-limit && bun run scripts/carbon-audit.ts --domains-only",
    "audit:sync": "bun run scripts/check-js-sync.ts",
    "audit:aeo": "bun run scripts/audit-aeo.ts",
    "check:version": "bun run scripts/check-version-bump.ts",
    "docs:api": "bun run scripts/generate-api-docs.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.0.1",
    "astropress": "workspace:*",
    "axe-core": "^4.10.3",
    "htmlparser2": "^12.0.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "size-limit": "^12.0.1"
  },
  "size-limit": [
    {
      "path": "examples/github-pages/dist/**/*.js",
      "limit": "10 KB",
      "running": false
    }
  ],
  "overrides": {
    "yaml": "^2.8.3"
  },
  "browserslist": [
    "Chrome >= 108",
    "Firefox >= 98",
    "Safari >= 15.4",
    "Edge >= 108"
  ]
}
