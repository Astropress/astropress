{
  "name": "astropress-monorepo",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "bdd:lint": "bun run tooling/scripts/bdd-lint.ts",
    "bdd:test": "bun run tooling/scripts/bdd-test.ts",
    "audit:deps": "bun audit",
    "audit:security": "bun run tooling/scripts/security-audit.ts",
    "audit:honesty": "bun run tooling/scripts/audit-honesty.ts",
    "audit:microcopy": "bun run tooling/scripts/audit-microcopy.ts",
    "audit:arch": "bun run tooling/scripts/arch-lint.ts",
    "audit:arch:rust": "bun run tooling/scripts/rust-arch-lint.ts",
    "audit:bundle": "bun run tooling/scripts/bundle-audit.ts",
    "test": "bun run audit:arch && bun run audit:arch:rust && bun run bdd:lint && bun run bdd:test && bun run --filter @astropress-diy/astropress test",
    "test:coverage": "bun run --filter @astropress-diy/astropress test:coverage",
    "test:cli:smoke": "cargo test doctor_ --manifest-path crates/astropress-cli/Cargo.toml && cargo test parses_top_level_commands --manifest-path crates/astropress-cli/Cargo.toml && cargo test deploy_target_prefers_explicit_env_target --manifest-path crates/astropress-cli/Cargo.toml && cargo test bootstraps_and_verifies_content_services --manifest-path crates/astropress-cli/Cargo.toml",
    "test:prepush": "bun run audit:arch && bun run audit:arch:rust && bun run bdd:lint && bun run docs:api:check && bun run --filter @astropress-diy/astropress test tests/runtime-env.test.ts tests/runtime-admin-auth.test.ts tests/cloudflare-adapter-security.test.ts tests/project-env.test.ts tests/content-services-ops.test.ts tests/hosted-provider.contract.test.ts tests/provider-targets.test.ts && bun run test:cli:smoke && bun run test:example && bun run repo:clean",
    "test:acceptance": "bun run tooling/scripts/run-playwright.ts --project=example-a11y --project=admin-harness-a11y --project=admin-harness-mobile --project=admin-harness-mobile-iphonese --project=admin-harness-mobile-galaxys5 --project=admin-harness-a11y-interactions --project=admin-harness-crud --project=admin-harness-smoke --project=viewport-375 --project=viewport-768 --project=viewport-1280",
    "test:consumer-smoke": "bun run tooling/scripts/run-consumer-smoke.ts",
    "test:tarball-smoke": "bun run tooling/scripts/run-tarball-smoke.ts",
    "build:example:clean": "bun run tooling/scripts/run-with-temp-data.ts bun run --filter astropress-example-gh-pages build",
    "check:example:clean": "bun run tooling/scripts/run-with-temp-data.ts bun run --filter astropress-example-gh-pages check",
    "check:admin-harness:clean": "bun run tooling/scripts/run-with-temp-data.ts bun run --filter astropress-example-admin-harness check",
    "test:accessibility": "bun run build:example:clean && bun run tooling/scripts/accessibility-audit.ts examples/github-pages/dist",
    "test:accessibility:browser": "bun run tooling/scripts/run-playwright.ts --project=example-a11y",
    "test:accessibility:admin-harness": "bun run tooling/scripts/run-playwright.ts --project=admin-harness-a11y",
    "test:admin-harness": "bun run check:admin-harness:clean",
    "test:cli": "cargo test --manifest-path crates/Cargo.toml",
    "test:example": "bun run check:example:clean",
    "test:static-site": "bun run build:example:clean && bun run tooling/scripts/static-site-audit.ts examples/github-pages/dist",
    "dev:example": "bun run --filter astropress-example-gh-pages dev",
    "audit:carbon": "bunx size-limit --config tooling/size-limit.json && bun run tooling/scripts/carbon-audit.ts --domains-only",
    "audit:aeo": "bun run tooling/scripts/audit-aeo.ts",
    "audit:providers": "bun run tooling/scripts/audit-providers.ts",
    "audit:cli-docs": "bun run tooling/scripts/audit-cli-docs.ts",
    "audit:env-contract": "bun run tooling/scripts/audit-env-contract.ts",
    "audit:exports": "bun run tooling/scripts/audit-exports.ts",
    "audit:crypto": "bun run tooling/scripts/audit-crypto.ts",
    "audit:web-components": "bun run tooling/scripts/audit-web-components.ts",
    "audit:navigation": "bun run tooling/scripts/audit-navigation.ts",
    "audit:interaction": "bun run tooling/scripts/audit-interaction.ts",
    "audit:error-handling": "bun run tooling/scripts/audit-error-handling.ts",
    "audit:caching": "bun run tooling/scripts/audit-caching.ts",
    "audit:nexus": "bun run tooling/scripts/audit-nexus.ts",
    "audit:developer-ergonomics": "bun run tooling/scripts/audit-developer-ergonomics.ts",
    "audit:dead-exports": "bun run tooling/scripts/audit-dead-exports.ts",
    "audit:bdd-wiring": "bun run tooling/scripts/audit-bdd-wiring.ts",
    "audit:no-stub-tests": "bun run tooling/scripts/audit-no-stub-tests.ts",
    "audit:consumer-packaging": "bun run tooling/scripts/audit-consumer-packaging.ts",
    "audit:admin-route-coverage": "bun run tooling/scripts/audit-admin-route-coverage.ts",
    "audit:title-composition": "bun run tooling/scripts/audit-title-composition.ts",
    "audit:security-policy-integrity": "bun run tooling/scripts/audit-security-policy-integrity.ts",
    "audit:user-facing-route-coverage": "bun run tooling/scripts/audit-user-facing-route-coverage.ts",
    "audit:evaluation-integrity": "bun run tooling/scripts/audit-evaluation-integrity.ts",
    "audit:observability": "bun run tooling/scripts/audit-observability.ts",
    "audit:api-design": "bun run tooling/scripts/audit-api-design.ts",
    "audit:ai-drivability": "bun run tooling/scripts/audit-ai-drivability.ts",
    "audit:i18n": "bun run tooling/scripts/audit-i18n.ts",
    "audit:content-modeling": "bun run tooling/scripts/audit-content-modeling.ts",
    "audit:collaboration": "bun run tooling/scripts/audit-collaboration.ts",
    "audit:oss-health": "bun run tooling/scripts/audit-oss-health.ts",
    "audit:scaffold-quality": "bun run tooling/scripts/audit-scaffold-quality.ts",
    "check:version": "bun run tooling/scripts/check-version-bump.ts",
    "docs:api": "bun run tooling/scripts/generate-api-docs.ts",
    "docs:api:check": "bun run tooling/scripts/generate-api-docs.ts --check",
    "docs:dev": "bun run --filter astropress-docs dev",
    "docs:build": "bun run --filter astropress-docs build",
    "docs:check": "bun run --filter astropress-docs check",
    "repo:clean": "bun run tooling/scripts/assert-clean-worktree.ts",
    "stress:sqlite": "bun run tooling/scripts/stress-sqlite-writes.ts",
    "release": "bun run --filter @astropress-diy/astropress release",
    "version": "bun run --filter @astropress-diy/astropress version",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "lefthook": "^1.13.6",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.0.1",
    "axe-core": "^4.11.2",
    "htmlparser2": "^12.0.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "size-limit": "^12.0.1",
    "typescript": "5.9.3",
    "@astropress-diy/astropress": "workspace:*"
  },
  "overrides": {
    "yaml": "^2.8.3",
    "vite": "^7.3.2",
    "astro": "^5.0.0"
  },
  "browserslist": [
    "Chrome >= 108",
    "Firefox >= 98",
    "Safari >= 15.4",
    "Edge >= 108"
  ],
  "engines": {
    "node": ">=24.8.0"
  }
}
