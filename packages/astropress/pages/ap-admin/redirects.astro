---
import AdminLayout from "@astropress-diy/astropress/components/AdminLayout.astro";
import AuditTrail from "@astropress-diy/astropress/components/AuditTrail.astro";
import CsrfInput from "@astropress-diy/astropress/components/CsrfInput.astro";
import { buildRedirectsPageModel } from "astropress";

const adminUser = Astro.locals.adminUser;
const model = await buildRedirectsPageModel(Astro.locals, adminUser?.role);
const { redirectRules, auditEvents } = model.data;
const wasSaved = Astro.url.searchParams.get("saved") === "1";
const wasDeleted = Astro.url.searchParams.get("deleted") === "1";
const errorMessage =
	Astro.url.searchParams.get("error") === "1"
		? Astro.url.searchParams.get("message")
		: "";

if (model.status === "forbidden") {
	Astro.response.status = 403;
}
---

{model.status !== "forbidden" ? (
  <AdminLayout
    title="Redirects"
    heading="Redirects"
    currentPath="/ap-admin/redirects"
    description="Reviewed redirect rules are manageable as product data."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    {model.warnings.length > 0 && <ap-notice type="info">Some redirect data is temporarily unavailable. This page is showing partial results.</ap-notice>}
    <div class="toolbar">
      <a href="#new-rule" class="admin-button">Add rule</a>
    </div>
    {wasSaved && <ap-notice type="success" dismiss-after="6000">The reviewed redirect rule was added successfully.</ap-notice>}
    {wasDeleted && <ap-notice type="success" dismiss-after="6000">The redirect rule was deleted successfully.</ap-notice>}
    {errorMessage && <ap-notice type="error">{errorMessage}</ap-notice>}
    <ap-pending-form>
    <form id="new-rule" class="panel redirect-form" method="post" action="/ap-admin/actions/redirect-create">
      <CsrfInput token={Astro.locals.csrfToken} />
      <div class="section-header">
        <div>
          <p class="admin-kicker">Create Redirect</p>
          <h2>New Redirect Rule</h2>
          <p>Add reviewed redirects as product data so old URLs stay intentional.</p>
        </div>
      </div>
      <label class="admin-field">
        <span>Legacy path</span>
        <input aria-label="Legacy path" type="text" name="sourcePath" placeholder="/fresh-start" class="admin-input" autofocus={Boolean(errorMessage)} />
      </label>
      <label class="admin-field">
        <span>Target path</span>
        <input aria-label="Target path" type="text" name="targetPath" placeholder="/about-us-2" class="admin-input" />
      </label>
      <label class="admin-field">
        <span>Status code</span>
        <select aria-label="Redirect status" name="statusCode" class="admin-select">
          <option value="301">301</option>
          <option value="302">302</option>
        </select>
      </label>
      <button type="submit" class="admin-button">Save rule</button>
    </form>
    </ap-pending-form>
    <section class="panel redirect-list-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Redirect Inventory</p>
          <h2>Reviewed Redirect Rules</h2>
          <p>Delete only when a route is intentionally retired or replaced elsewhere.</p>
        </div>
      </div>
      <div class="admin-table-shell">
        <table aria-label="Redirect rules">
          <thead>
            <tr>
              <th>Legacy</th>
              <th>Target</th>
              <th>Status</th>
              <th>Delete</th>
            </tr>
          </thead>
          <tbody>
            {redirectRules.map((rule) => (
              <tr>
                <td>
                  <code>{rule.sourcePath}</code>
                  <button type="button" class="copy-path-btn admin-button-ghost small" data-copy={rule.sourcePath} aria-label={`Copy ${rule.sourcePath}`}>Copy</button>
                </td>
                <td><code>{rule.targetPath}</code></td>
                <td><span class="admin-chip">{rule.statusCode}</span></td>
                <td>
                  <button
                    type="button"
                    class="admin-button-ghost small delete-button"
                    data-confirm-delete
                    data-confirm-trigger
                    data-dialog-id="confirm-dialog"
                    data-text-dialog-source={rule.sourcePath}
                    data-text-dialog-target={rule.targetPath}
                    data-field-name="sourcePath"
                    data-field-value={rule.sourcePath}
                  >
                    Delete
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    {/* Confirmation Dialog */}
    <ap-confirm-dialog>
      <dialog id="confirm-dialog" class="confirm-modal" aria-labelledby="confirm-dialog-title">
        <div class="modal-content">
          <h2 id="confirm-dialog-title">Delete redirect rule?</h2>
          <p>
            Are you sure you want to delete this redirect rule?
          </p>
          <p class="dialog-context">
            <strong id="dialog-source"></strong> → <strong id="dialog-target"></strong>
          </p>
          <p class="dialog-warning">This action cannot be undone.</p>
          <div class="modal-actions">
            <button type="button" class="admin-button-ghost small secondary-button" data-dialog-close>Cancel</button>
            <form id="confirm-form" method="post" style="display: inline;">
              <CsrfInput token={Astro.locals.csrfToken} />
              <input type="hidden" name="sourcePath" value="" />
              <button type="submit" class="admin-button small delete-button">Delete Rule</button>
            </form>
          </div>
        </div>
      </dialog>
    </ap-confirm-dialog>
    <AuditTrail events={auditEvents.filter((event) => event.targetType === "redirect").slice(0, 5)} />
    <script>
      import "../../web-components/confirm-dialog";
    </script>
  </AdminLayout>
) : (
  <AdminLayout
    title="Forbidden"
    heading="Forbidden"
    currentPath=""
    description="This action requires an admin account."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    <section class="panel forbidden">
      <p>This action requires an admin account and is hidden from editor-only roles.</p>
    </section>
  </AdminLayout>
)}

<style>
  .redirect-form {
    display: grid;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .redirect-list-panel {
    display: grid;
    gap: 1rem;
  }

  input,
  select,
  button {
    font: inherit;
  }

  .delete-form {
    display: flex;
  }

  .delete-button {
    border-color: color-mix(in srgb, var(--danger) 50%, var(--line));
    color: var(--danger);
  }


  .copy-path-btn {
    margin-left: 0.4rem;
    font-size: 0.78rem;
    padding: 0.15rem 0.45rem;
    vertical-align: middle;
  }
</style>

<script>
  // Clipboard API: copy source path on button click
  document.addEventListener("click", async (event) => {
    const btn = (event.target as Element).closest<HTMLElement>("[data-copy]");
    if (!btn) return;
    const text = btn.getAttribute("data-copy") ?? "";
    if (!text || !navigator.clipboard) return;
    await navigator.clipboard.writeText(text);
    const original = btn.textContent;
    btn.textContent = "Copied!";
    setTimeout(() => { btn.textContent = original; }, 1500);
  });
</script>
