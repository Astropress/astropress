---
import AdminLayout from "astropress/components/AdminLayout.astro";
import AuditTrail from "astropress/components/AuditTrail.astro";
import CsrfInput from "astropress/components/CsrfInput.astro";
import { buildPostEditorPageModel } from "astropress";
import { getAdminLocalePair } from "astropress";
import { getSeededAdminContentType } from "astropress";
import { peekCmsConfig } from "../../src/config.js";

export const prerender = false;

const adminUser = Astro.locals.adminUser;
const slug = Astro.params.slug ?? "";
const model = await buildPostEditorPageModel(Astro.locals, slug);
const { pageRecord, authors, categories, tags, auditEvents, englishOwnerRecord, localizedRouteRecord, effectiveTranslationState } = model.data;
const wasSaved = Astro.url.searchParams.get("saved") === "1";
const errorMessage = Astro.url.searchParams.get("error") === "1" ? Astro.url.searchParams.get("message") : "";
const contentType = pageRecord ? getSeededAdminContentType(pageRecord) : "post";
const contentLabel = contentType === "page" ? "Page" : "Post";
const listPath = contentType === "page" ? "/ap-admin/pages" : "/ap-admin/posts";
const localePair = pageRecord ? getAdminLocalePair(pageRecord.legacyUrl) : null;
const englishEditorHref = englishOwnerRecord ? `/ap-admin/posts/${englishOwnerRecord.slug}` : undefined;
const localizedEditorHref = localizedRouteRecord ? `/ap-admin/route-pages${localizedRouteRecord.path}` : undefined;
const publicHref = pageRecord?.legacyUrl || "/";
const publicStatus = pageRecord?.status ?? "published";

// Resolve the registered ContentTypeDefinition for this record's templateKey, if any.
// Used to auto-generate custom field inputs in the editor.
const registeredContentTypes = peekCmsConfig()?.contentTypes ?? [];
const registeredContentType = pageRecord
  ? registeredContentTypes.find((ct) => ct.key === pageRecord.templateKey) ?? null
  : null;
const customFields = registeredContentType?.fields ?? [];
const currentMetadata = (pageRecord?.metadata ?? {}) as Record<string, unknown>;

if (adminUser?.role !== "admin" && contentType === "page") {
  Astro.response.status = 403;
}

if (model.status === "not_found") {
  Astro.response.status = 404;
}
---

{pageRecord && !(adminUser?.role !== "admin" && contentType === "page") ? (
  <AdminLayout
    title={`Edit ${contentLabel} | ${pageRecord.title}`}
    heading={`Edit ${contentLabel}`}
    currentPath={listPath}
    description={contentType === "page" ? "Seeded page content and metadata." : "Blog post content, taxonomy, scheduling, and metadata."}
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    {model.warnings.length > 0 && <ap-notice type="info">Some editor data is temporarily unavailable. This page is showing partial results.</ap-notice>}
    <div class="toolbar">
      <a href={listPath} class="admin-button-secondary">{contentType === "page" ? "Back to pages" : "Back to posts"}</a>
      <a href={publicHref} target="_blank" rel="noreferrer" class="admin-button-ghost">Open public {contentType === "page" ? "page" : "post"}</a>
      <a href={`/ap-admin/posts/${pageRecord.slug}/revisions`} class="admin-button-ghost">View revisions</a>
    </div>
    {wasSaved && <ap-notice type="success" dismiss-after="6000">Changes saved successfully</ap-notice>}
    {errorMessage && <ap-notice type="error">{errorMessage}</ap-notice>}

    <ap-html-editor>
    <form method="post" action="/ap-admin/actions/content-save" class="edit-form">
      <CsrfInput token={Astro.locals.csrfToken} />
      <input type="hidden" name="slug" value={pageRecord.slug} />
      <input type="hidden" name="lastKnownUpdatedAt" value={pageRecord.updatedAt} />

      {/* Panel 1: Publish */}
      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Publish</h2>
            <p>Manage the public title, status, route timing, and saved record identity.</p>
          </div>
        </div>
        <p class="field-note">Public route: <a href={publicHref} target="_blank" rel="noreferrer">{publicHref}</a> · Current status: <strong>{publicStatus}</strong></p>
        <label class="admin-field">
          <span>Title</span>
          <input aria-label="Content title" type="text" name="title" value={pageRecord.title} class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Status</span>
          <select aria-label="Publish status" name="status" class="admin-select">
            <option value="published" selected={pageRecord.status === "published"}>Published</option>
            <option value="review" selected={pageRecord.status === "review"}>In Review</option>
            <option value="draft" selected={pageRecord.status === "draft"}>Draft</option>
            <option value="archived" selected={pageRecord.status === "archived"}>Archived</option>
          </select>
        </label>
        <label class="admin-field">
          <span>Scheduled Publish Time</span>
          <input
            aria-label="Scheduled publish time"
            type="datetime-local"
            name="scheduledAt"
            value={pageRecord.scheduledAt ? new Date(pageRecord.scheduledAt).toISOString().slice(0, 16) : ""}
            class="admin-input"
          />
        </label>
        <label class="admin-field">
          <span>Slug</span>
          <input type="text" aria-label="Slug" value={pageRecord.slug} readonly tabindex="-1" class="admin-input" />
        </label>
      </section>

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Authorship & Taxonomy</h2>
            <p>Assign this record to the people and archive families that should own it publicly.</p>
          </div>
        </div>
        <div class="taxonomy-columns">
          <fieldset>
            <legend>Authors</legend>
            {authors.length > 0 ? authors.map((author) => (
              <label class="checkbox-row">
                <input type="checkbox" name="authorIds" value={author.id} checked={pageRecord.authorIds?.includes(author.id)} />
                <span>{author.name}</span>
              </label>
            )) : <p class="field-note">No authors available yet.</p>}
          </fieldset>
          <fieldset>
            <legend>Categories</legend>
            {categories.length > 0 ? categories.map((term) => (
              <label class="checkbox-row">
                <input type="checkbox" name="categoryIds" value={term.id} checked={pageRecord.categoryIds?.includes(term.id)} />
                <span>{term.name}</span>
              </label>
            )) : <p class="field-note">No categories available yet.</p>}
          </fieldset>
          <fieldset>
            <legend>Tags</legend>
            {tags.length > 0 ? tags.map((term) => (
              <label class="checkbox-row">
                <input type="checkbox" name="tagIds" value={term.id} checked={pageRecord.tagIds?.includes(term.id)} />
                <span>{term.name}</span>
              </label>
            )) : <p class="field-note">No tags available yet.</p>}
          </fieldset>
        </div>
      </section>

      {/* Panel 2: Body */}
      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Body</h2>
            <p>Reviewed HTML. Unsafe scripts and handlers are stripped during save.</p>
          </div>
        </div>
        <p class="field-note">Reviewed HTML. Scripts, inline handlers, and unsafe embeds are stripped on save.</p>
        <div role="toolbar" aria-label="Format body" class="body-toolbar">
          <button type="button" class="toolbar-btn" data-cmd="bold" aria-label="Bold"><strong>B</strong></button>
          <button type="button" class="toolbar-btn" data-cmd="italic" aria-label="Italic"><em>I</em></button>
          <button type="button" class="toolbar-btn" data-cmd="insertUnorderedList" aria-label="Bullet list">&#8226; List</button>
          <button type="button" class="toolbar-btn" data-cmd="createLink" aria-label="Insert link">Link</button>
          <button type="button" class="toolbar-btn insert-media-btn" aria-label="Open media library">Open media library</button>
        </div>
        <label class="admin-field">
          <span>Body HTML</span>
          <textarea aria-label="Body HTML" name="body" rows="14" class="admin-textarea code-field body-editor" data-body-editor>{pageRecord.body}</textarea>
        </label>
      </section>

      {/* Media library dialog */}
      <dialog class="media-dialog" aria-labelledby="media-library-title" id="media-library-dialog">
        <div class="media-dialog-inner">
          <h2 id="media-library-title">Media Library</h2>
          <p class="field-note">Select an image to insert into the body.</p>
          <div class="media-grid" id="media-grid-placeholder">
            <p class="field-note">No media files available yet. Upload images via the server to make them available here.</p>
          </div>
          <div class="media-dialog-actions">
            <button type="button" class="admin-button-ghost" id="media-dialog-close">Close</button>
          </div>
        </div>
      </dialog>

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Preview</h2>
            <p>Rendered preview of the currently reviewed body state.</p>
          </div>
        </div>
        <p class="field-note">Rendered preview of the currently reviewed body state.</p>
        <div class="preview-frame">
          <iframe
            title="Rendered preview"
            sandbox=""
            srcdoc={`<!doctype html><html lang="en"><head><meta charset="utf-8"><style>body{font-family:Georgia,serif;padding:1rem;line-height:1.6;color:#17212c}</style></head><body>${pageRecord.body}</body></html>`}
          />
        </div>
      </section>

      {/* Panel 3: Excerpt */}
      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Excerpt</h2>
            <p>Short summary text used in cards, previews, and metadata fallbacks.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>Summary / Excerpt</span>
          <textarea aria-label="Content excerpt" rows="4" name="excerpt" placeholder="Brief summary of this content..." class="admin-textarea">{("excerpt" in pageRecord ? pageRecord.excerpt : "") || pageRecord.summary}</textarea>
        </label>
      </section>

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Revision Note</h2>
            <p>Leave a short change summary so the revision history stays useful for editors.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>Change summary</span>
          <textarea aria-label="Revision note" rows="3" name="revisionNote" placeholder="Summarize what changed in this revision." class="admin-textarea" />
        </label>
      </section>

      {/* Panel 4: SEO */}
      <section class="panel">
        <div class="section-header">
          <div>
            <h2>SEO</h2>
            <p>Title and description defaults for search and internal sharing surfaces.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>SEO Title</span>
          <input aria-label="SEO title" type="text" name="seoTitle" value={pageRecord.seoTitle || pageRecord.title} class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Meta Description</span>
          <textarea aria-label="Meta description" rows="3" name="metaDescription" class="admin-textarea">{pageRecord.metaDescription || pageRecord.summary}</textarea>
        </label>
      </section>

      {/* Panel 5: OG / Social */}
      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Open Graph & Social</h2>
            <p>Optional overrides for shared previews when social platforms need something more tailored.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>OG Title</span>
          <input aria-label="OG title" type="text" name="ogTitle" value={pageRecord.ogTitle || ""} placeholder="Defaults to SEO title" class="admin-input" />
        </label>
        <label class="admin-field">
          <span>OG Description</span>
          <textarea aria-label="OG description" rows="3" name="ogDescription" placeholder="Defaults to meta description" class="admin-textarea">{pageRecord.ogDescription || ""}</textarea>
        </label>
        <label class="admin-field">
          <span>OG Image URL</span>
          <input aria-label="OG image URL" type="url" name="ogImage" value={pageRecord.ogImage || ""} placeholder="https://example.com/image.jpg" class="admin-input" />
        </label>
      </section>

      {/* Panel 6: Canonical & Robots */}
      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Canonical & Robots</h2>
            <p>Override the default route metadata only when you have a specific indexing reason.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>Canonical URL Override</span>
          <input aria-label="Canonical URL" type="url" name="canonicalUrlOverride" value={pageRecord.canonicalUrlOverride || ""} placeholder="Leave empty for default" class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Robots Directive</span>
          <select aria-label="Robots directive" name="robotsDirective" class="admin-select">
            <option value="">Default (index, follow)</option>
            <option value="noindex" selected={pageRecord.robotsDirective === "noindex"}>noindex</option>
            <option value="nofollow" selected={pageRecord.robotsDirective === "nofollow"}>nofollow</option>
            <option value="noindex, nofollow" selected={pageRecord.robotsDirective === "noindex, nofollow"}>noindex, nofollow</option>
          </select>
        </label>
      </section>

      {/* Panel 7: Locale & Translations */}
      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Locale & Translations</h2>
            <p>Open the linked locale owner directly and manage translation state without leaving this editor.</p>
          </div>
        </div>
        <p class="field-note">Current locale: <strong>{localePair?.currentLocale === "es" ? "es" : "en"}</strong></p>
        {localePair ? (
          <>
            <div class="locale-links">
              {englishEditorHref && <a href={englishEditorHref} class="admin-button-ghost small">Edit English variant</a>}
              {localizedEditorHref && <a href={localizedEditorHref} class="admin-button-ghost small">Edit Spanish variant</a>}
              <a href="/ap-admin/translations" class="admin-button-ghost small">Open translation coverage</a>
            </div>
            {adminUser?.role === "admin" && localePair.localizedRoute ? (
              <div class="translation-inline-form">
                <input type="hidden" name="route" value={localePair.localizedRoute} />
                <input type="hidden" name="returnPath" value={`/ap-admin/posts/${pageRecord.slug}`} />
                <label class="admin-field">
                  <span>Translation state</span>
                  <select name="state" aria-label="Translation state" class="admin-select">
                    <option value="not_started" selected={effectiveTranslationState === "not_started"}>Not started</option>
                    <option value="partial" selected={effectiveTranslationState === "partial"}>Partial</option>
                    <option value="fallback_en" selected={effectiveTranslationState === "fallback_en"}>Fallback to English</option>
                    <option value="translated" selected={effectiveTranslationState === "translated"}>Translated</option>
                    <option value="reviewed" selected={effectiveTranslationState === "reviewed"}>Reviewed</option>
                    <option value="published" selected={effectiveTranslationState === "published"}>Published</option>
                  </select>
                </label>
                <button type="submit" formaction="/ap-admin/actions/translation-update" formmethod="post" class="admin-button small">Update translation state</button>
              </div>
            ) : (
              <p class="field-note">Translation state is managed by admins.</p>
            )}
          </>
        ) : (
          <p class="field-note">No linked locale variant is currently configured for this {contentLabel.toLowerCase()}.</p>
        )}
      </section>

      {/* Panel 8: Legacy Reference */}
      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Legacy Reference</h2>
            <p>Imported-source details for tracing this record back to the old site.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>Legacy URL</span>
          <input type="text" value={pageRecord.legacyUrl} readonly class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Source HTML Path</span>
          <input type="text" value={pageRecord.sourceHtmlPath} readonly class="admin-input code-field" />
        </label>
        <p class="field-note">This content was imported from the legacy site. Reviewed HTML overrides now take precedence on the public route.</p>
      </section>

      {/* Panel: Custom fields — auto-generated from registered ContentTypeDefinition */}
      {customFields.length > 0 && (
        <section class="panel" data-ap-custom-fields>
          <div class="section-header">
            <div>
              <h2>{registeredContentType!.label} Fields</h2>
              <p>Custom fields defined for this content type in <code>registerCms()</code>.</p>
            </div>
          </div>
          {customFields.map((field) => {
            const fieldName = `metadata.${field.name}`;
            const currentValue = currentMetadata[field.name];
            const labelText = `${field.label}${field.required ? " *" : ""}`;

            if (field.type === "boolean") {
              return (
                <label class="admin-field admin-field--checkbox">
                  <input
                    type="checkbox"
                    name={fieldName}
                    value="true"
                    checked={Boolean(currentValue)}
                  />
                  <span>{labelText}</span>
                </label>
              );
            }

            if (field.type === "select" && field.options) {
              return (
                <label class="admin-field">
                  <span>{labelText}</span>
                  <select name={fieldName} class="admin-input" required={field.required}>
                    <option value="">— Select —</option>
                    {field.options.map((opt) => (
                      <option value={opt} selected={currentValue === opt}>{opt}</option>
                    ))}
                  </select>
                </label>
              );
            }

            // Default: text input
            return (
              <label class="admin-field">
                <span>{labelText}</span>
                <input
                  type="text"
                  name={fieldName}
                  value={String(currentValue ?? "")}
                  class="admin-input"
                  required={field.required}
                />
              </label>
            );
          })}
        </section>
      )}

      <div class="form-actions">
        <button type="submit" class="admin-button">Save reviewed changes</button>
        <a href={listPath} class="admin-button-ghost secondary-button">Cancel</a>
      </div>
    </form>

    {/* URL input dialog — replaces window.prompt() for the Insert Link toolbar action */}
    <dialog id="url-input-dialog" class="url-input-dialog" aria-labelledby="url-input-title">
      <div class="modal-content">
        <h2 id="url-input-title">Insert link</h2>
        <form id="url-input-form" method="dialog">
          <label class="admin-field">
            <span>URL</span>
            <input id="url-input-field" type="url" name="url" placeholder="https://" class="admin-input" />
          </label>
          <div class="modal-actions">
            <button type="button" class="admin-button-ghost small" data-dialog-close>Cancel</button>
            <button type="submit" class="admin-button small">Insert link</button>
          </div>
        </form>
      </div>
    </dialog>

    </ap-html-editor>

    <AuditTrail events={auditEvents.filter((event) => event.targetType === "content").slice(0, 5)} />

    <script>
      import "../../../web-components/html-editor";
    </script>
  </AdminLayout>
) : (
  <AdminLayout
    title={adminUser?.role !== "admin" && contentType === "page" ? "Forbidden | Astropress Admin" : "Not Found | Astropress Admin"}
    heading={adminUser?.role !== "admin" && contentType === "page" ? "Forbidden" : "Not Found"}
    currentPath="/ap-admin/posts"
    description={adminUser?.role !== "admin" && contentType === "page" ? "This action requires an admin account." : "The requested content record could not be found."}
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    <section class="panel">
      <p>{adminUser?.role !== "admin" && contentType === "page" ? "This action requires an admin account and is hidden from editor-only roles." : "The requested content record could not be found."}</p>
    </section>
  </AdminLayout>
)}

<style>
  .edit-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  input[readonly],
  textarea[readonly] {
    background: var(--bg);
    color: var(--muted);
    cursor: not-allowed;
  }

  .field-note {
    margin: -0.75rem 0 1rem 0;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .locale-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .translation-inline-form {
    display: grid;
    gap: 0.75rem;
  }

  .translation-inline-form label {
    margin-bottom: 0;
  }

  .translation-inline-form button {
    justify-self: start;
  }

  .toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .toolbar a,
  .locale-links a,
  .field-note a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: none;
  }

  .toolbar a:hover,
  .locale-links a:hover,
  .field-note a:hover {
    text-decoration: underline;
  }

  .preview-frame {
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--panel) 95%, var(--accent-soft) 5%);
    overflow: hidden;
  }

  .preview-frame iframe {
    display: block;
    width: 100%;
    min-height: 18rem;
    border: 0;
    background: transparent;
  }

  .taxonomy-columns {
    display: grid;
    gap: 1rem;
  }

  fieldset {
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    padding: 0.9rem 1rem 1rem;
  }

  legend {
    padding: 0 0.3rem;
    font-weight: 700;
  }

  .checkbox-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.55rem;
  }

  .checkbox-row input {
    width: auto;
    margin: 0;
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .code-field {
    font-family: "Monaco", monospace;
    font-size: 0.85rem;
  }

  .body-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--line);
    border-bottom: none;
    border-radius: 0.65rem 0.65rem 0 0;
    background: color-mix(in srgb, var(--panel) 90%, var(--accent-soft) 10%);
  }

  .toolbar-btn {
    border: 1px solid var(--line);
    border-radius: 0.4rem;
    padding: 0.25rem 0.6rem;
    background: var(--panel);
    color: var(--text);
    font: inherit;
    font-size: 0.85rem;
    cursor: pointer;
  }

  .toolbar-btn:hover {
    background: var(--accent-soft);
  }

  .body-editor {
    min-height: 12rem;
    padding: 0.75rem;
    border: 1px solid var(--line);
    border-radius: 0 0 0.65rem 0.65rem;
    background: var(--panel);
    color: var(--text);
    font: inherit;
    line-height: 1.6;
    outline: none;
  }

  .body-editor:focus {
    border-color: var(--accent);
  }

  .media-dialog {
    border: none;
    border-radius: 1rem;
    padding: 0;
    max-width: 48rem;
    width: 90vw;
    box-shadow: 0 4px 24px rgba(0,0,0,0.18);
  }

  .media-dialog-inner {
    padding: 1.5rem;
  }

  .media-grid {
    margin: 1rem 0;
    min-height: 4rem;
  }

  .media-dialog-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .url-input-dialog {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-width: 28rem;
    width: 90vw;
    padding: 0;
  }

  .url-input-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }

  .modal-content {
    padding: 1.5rem;
  }

  .modal-content h2 {
    margin: 0 0 1rem;
    font-size: 1.15rem;
  }

  .modal-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
    margin-top: 1rem;
  }

  @media (max-width: 900px) {
    .edit-form {
      gap: 1rem;
    }
  }
</style>
