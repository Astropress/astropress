---
import AdminLayout from "@astropress-diy/astropress/components/AdminLayout.astro";
import CsrfInput from "@astropress-diy/astropress/components/CsrfInput.astro";
import { buildTranslationsPageModel } from "astropress";
import { translationStates } from "astropress";

const adminUser = Astro.locals.adminUser;
const model = await buildTranslationsPageModel(Astro.locals, adminUser!.role);
if (model.status === "forbidden") {
  Astro.response.status = 403;
}

const wasSaved = Astro.url.searchParams.get("saved") === "1";
const validStates = [...translationStates];
const selectedState = Astro.url.searchParams.get("state") ?? "all";
const rows = model.data.rows;
const filteredRows = rows.filter((entry) => selectedState === "all" || entry.effectiveState === selectedState);
const stateCounts = rows.reduce<Record<string, number>>((accumulator, entry) => {
  accumulator[entry.effectiveState] = (accumulator[entry.effectiveState] ?? 0) + 1;
  return accumulator;
}, {});
---

{model.status !== "forbidden" ? (
  <AdminLayout
    title="Translations"
    heading="Translations"
    currentPath="/ap-admin/translations"
    description="Translation coverage and state. Edit content inside the owning page or route editor."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    {model.warnings.length > 0 && <p class="notice">Some translation records are temporarily unavailable. This page is showing partial results.</p>}
    {wasSaved && <p class="notice">Translation state updated successfully.</p>}
    <div class="admin-subgrid two summary-grid">
      <section class="panel stat summary-card">
        <span>Localized routes</span>
        <strong>{rows.length}</strong>
        <span>Spanish routes currently tracked in translation coverage.</span>
      </section>
      <section class="panel stat summary-card">
        <span>Published translations</span>
        <strong>{stateCounts.published ?? 0}</strong>
        <span>Routes that are ready and publicly published in Spanish.</span>
      </section>
    </div>
    <section class="panel translations-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Coverage</p>
          <h2>Translation Coverage</h2>
          <p>Use this screen to triage untranslated routes, then jump into the owning editor to make content changes.</p>
        </div>
        <form method="get" class="translation-filter">
          <label>
            <span class="sr-only">Filter translations by state</span>
            <select class="admin-select" name="state" aria-label="Filter translations by state">
              <option value="all" selected={selectedState === "all"}>All states</option>
              {validStates.map((state) => (
                <option value={state} selected={selectedState === state}>
                  {state}
                </option>
              ))}
            </select>
          </label>
          <button type="submit" class="admin-button">Apply</button>
        </form>
      </div>
      <p><strong>{filteredRows.length} of {rows.length} localized routes</strong></p>
      <div class="admin-table-shell">
        <table aria-label="Translation coverage">
          <thead>
            <tr>
              <th>Route</th>
              <th>Locale</th>
              <th>English source</th>
              <th>Status</th>
              <th>Edit</th>
              <th>Update</th>
            </tr>
          </thead>
          <tbody>
            {filteredRows.map((entry) => {
              const effectiveState = entry.effectiveState;
              return (
                <tr>
                  <td><code>{entry.route}</code></td>
                  <td>{entry.locale}</td>
                  <td><code>{entry.englishSourceUrl}</code></td>
                  <td><span class="admin-chip">{effectiveState}</span></td>
                  <td class="edit-links">
                    {entry.englishEditHref && <a href={entry.englishEditHref} class="admin-button-ghost small">Edit EN</a>}
                    {entry.localizedEditHref && <a href={entry.localizedEditHref} class="admin-button-ghost small">Edit locale</a>}
                  </td>
                  <td>
                    <form method="post" action="/ap-admin/actions/translation-update" class="translation-update">
                      <CsrfInput token={Astro.locals.csrfToken} />
                      <input type="hidden" name="route" value={entry.route} />
                      <select class="admin-select" name="state" required>
                        {validStates.map((state) => (
                          <option value={state} selected={effectiveState === state}>
                            {state}
                          </option>
                        ))}
                      </select>
                      <button type="submit" class="admin-button-ghost small">Update</button>
                    </form>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  </AdminLayout>
) : (
  <AdminLayout
    title="Forbidden"
    heading="Forbidden"
    currentPath="/ap-admin/posts"
    description="This action requires an admin account."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    <section class="panel">
      <p>This action requires an admin account and is hidden from editor-only roles.</p>
    </section>
  </AdminLayout>
)}

<style>
  .summary-grid {
    margin-bottom: 1rem;
  }

  .summary-card span:first-child {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 700;
  }

  .summary-card span:last-child {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .translations-panel {
    display: grid;
    gap: 1rem;
  }

  .translation-filter {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .translation-update {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .translation-filter select,
  .translation-update select {
    min-width: 9rem;
  }

  .translation-filter button,
  .translation-update button {
    padding: 0;
  }

  .edit-links {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
</style>
