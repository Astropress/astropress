---
import AdminLayout from "@astropress-diy/astropress/components/AdminLayout.astro";
import CsrfInput from "@astropress-diy/astropress/components/CsrfInput.astro";
import { buildRoutePageEditorModel } from "astropress";
import { getAdminLocalePair } from "astropress";

export const prerender = false;

const adminUser = Astro.locals.adminUser;
const slugSegments = Array.isArray(Astro.params.slug) ? Astro.params.slug : Astro.params.slug ? [Astro.params.slug] : [];
const routePath = `/${slugSegments.join("/")}`;
const model = await buildRoutePageEditorModel(Astro.locals, routePath, adminUser!.role);
const { pageRecord, englishOwner, effectiveTranslationState } = model.data;
const wasSaved = Astro.url.searchParams.get("saved") === "1";
const errorMessage = Astro.url.searchParams.get("error") === "1" ? Astro.url.searchParams.get("message") : "";
const localePair = getAdminLocalePair(routePath);
const localizedRoutePath = localePair?.localizedRoute;

if (model.status === "forbidden") {
  Astro.response.status = 403;
}

if (model.status === "not_found") {
  Astro.response.status = 404;
}
---

{pageRecord && model.status !== "forbidden" ? (
  <AdminLayout
    title={`Edit Route Table Record | ${pageRecord.title}`}
    heading="Edit Route Table Record"
    currentPath="/ap-admin/route-pages"
    description="Technical editing for route-backed structured pages. Use Pages for the normal editorial entry point."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/ap-admin/route-pages">Route Pages</a>
      <span aria-hidden="true"> / </span>
      <span aria-current="page">{pageRecord.title || routePath}</span>
    </nav>
    {model.warnings.length > 0 && <p class="notice">Some route-page data is temporarily unavailable. This page is showing partial results.</p>}
    <div class="toolbar">
      <a href="/ap-admin/pages" class="admin-button-secondary">Back to pages</a>
      <a href={pageRecord.path} target="_blank" rel="noreferrer" class="admin-button-ghost">Open public page</a>
      <a href="/ap-admin/route-pages" class="admin-button-ghost">Open route table</a>
    </div>
    {(wasSaved || Astro.url.searchParams.get("created") === "1") && <p class="notice">Route page saved successfully.</p>}
    {errorMessage && <p class="error-notice">{errorMessage}</p>}

    <form method="post" action="/ap-admin/actions/route-page-save" class="edit-form">
      <CsrfInput token={Astro.locals.csrfToken} />
      <input type="hidden" name="path" value={pageRecord.path} />
      <input type="hidden" name="templateKey" value={pageRecord.templateKey} />

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>General</h2>
            <p>Public route identity, summary copy, and metadata defaults for this structured page.</p>
          </div>
        </div>
        <p class="field-note">Public route: <a href={pageRecord.path} target="_blank" rel="noreferrer">{pageRecord.path}</a> · Template: <strong>{pageRecord.templateKey}</strong></p>
        <label class="admin-field">
          <span>Title</span>
          <input type="text" aria-label="Route page title" name="title" value={pageRecord.title} required class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Summary</span>
          <textarea aria-label="Route page summary" rows="3" name="summary" class="admin-textarea">{pageRecord.summary ?? ""}</textarea>
        </label>
        <label class="admin-field">
          <span>Canonical URL</span>
          <input type="url" aria-label="Canonical URL" name="canonicalUrlOverride" value={pageRecord.canonicalUrlOverride ?? ""} class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Robots</span>
          <input type="text" aria-label="Robots directive" name="robotsDirective" value={pageRecord.robotsDirective ?? ""} class="admin-input" />
        </label>
        <label class="admin-field">
          <span>OG Image</span>
          <input type="text" aria-label="OG image" name="ogImage" value={pageRecord.ogImage ?? ""} class="admin-input" />
        </label>
      </section>

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Owner & Locale</h2>
            <p>Jump back to the main owner editor or switch to the linked locale record from here.</p>
          </div>
        </div>
        <p class="field-note">This technical route record belongs to the main Pages workflow.</p>
        <div class="editor-links">
          <a href="/ap-admin/pages" class="admin-button-ghost small">Open Pages index</a>
          <a href={pageRecord.path} target="_blank" rel="noreferrer" class="admin-button-ghost small">Open public route</a>
          {englishOwner && <a href={`/ap-admin/posts/${englishOwner.slug}`} class="admin-button-ghost small">Edit English owner</a>}
          {localePair?.englishRoute && localePair.englishRoute !== routePath && !englishOwner && (
            <a href={`/ap-admin/route-pages${localePair.englishRoute}`} class="admin-button-ghost small">Edit English variant</a>
          )}
          {localizedRoutePath && localizedRoutePath !== routePath && (
            <a href={`/ap-admin/route-pages${localizedRoutePath}`} class="admin-button-ghost small">Edit Spanish variant</a>
          )}
        </div>
        {localizedRoutePath && (
          <div class="translation-inline-form">
            <input type="hidden" name="route" value={localizedRoutePath} />
            <input type="hidden" name="returnPath" value={`/ap-admin/route-pages${pageRecord.path}`} />
            <label class="admin-field">
              <span>Translation state</span>
              <select name="state" aria-label="Translation state" class="admin-select">
                <option value="not_started" selected={effectiveTranslationState === "not_started"}>Not started</option>
                <option value="partial" selected={effectiveTranslationState === "partial"}>Partial</option>
                <option value="fallback_en" selected={effectiveTranslationState === "fallback_en"}>Fallback to English</option>
                <option value="translated" selected={effectiveTranslationState === "translated"}>Translated</option>
                <option value="reviewed" selected={effectiveTranslationState === "reviewed"}>Reviewed</option>
                <option value="published" selected={effectiveTranslationState === "published"}>Published</option>
              </select>
            </label>
            <button type="submit" formaction="/ap-admin/actions/translation-update" formmethod="post" class="admin-button small">Update translation state</button>
          </div>
        )}
      </section>

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>SEO</h2>
            <p>Search-facing title and description for the route-backed page.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>SEO Title</span>
          <input type="text" aria-label="SEO title" name="seoTitle" value={pageRecord.seoTitle ?? pageRecord.title} class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Meta Description</span>
          <textarea aria-label="Meta description" rows="3" name="metaDescription" class="admin-textarea">{pageRecord.metaDescription ?? pageRecord.summary ?? ""}</textarea>
        </label>
      </section>

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Alternate Links</h2>
            <p>Hreflang mapping for linked English and Spanish route variants.</p>
          </div>
        </div>
        {pageRecord.alternateLinks.length > 0 && (
          <p class="field-note">
            {pageRecord.alternateLinks.map((link) => (
              <a href={`/ap-admin/route-pages${link.href.replace(/^https?:\/\/[^/]+/, "")}`} class="admin-button-ghost small">{link.hreflang}</a>
            ))}
          </p>
        )}
        <textarea aria-label="Alternate links JSON" rows="6" name="alternateLinksJson" class="admin-textarea code-field">{JSON.stringify(pageRecord.alternateLinks, null, 2)}</textarea>
      </section>

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Sections JSON</h2>
            <p>Structured section payload for the marketing page renderer.</p>
          </div>
        </div>
        <p class="field-note">This slice uses structured JSON editing for registry-backed marketing pages.</p>
        <textarea aria-label="Sections JSON" rows="20" name="sectionsJson" class="admin-textarea code-field">{JSON.stringify(pageRecord.sections ?? {}, null, 2)}</textarea>
      </section>

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>Revision Note</h2>
            <p>Summarize the change so the route revision history stays understandable.</p>
          </div>
        </div>
        <input type="text" aria-label="Revision note" name="revisionNote" placeholder="Summarize this change" class="admin-input" />
      </section>

      <div class="form-actions">
        <button type="submit" class="admin-button">Save route page</button>
        <a href="/ap-admin/route-pages" class="admin-button-ghost secondary-button">Back to route table</a>
      </div>
    </form>
  </AdminLayout>
) : (
  <AdminLayout
    title={adminUser?.role !== "admin" ? "Forbidden" : "Not Found"}
    heading={adminUser?.role !== "admin" ? "Forbidden" : "Not Found"}
    currentPath="/ap-admin/route-pages"
    description={adminUser?.role !== "admin" ? "This action requires an admin account." : "The requested route page could not be found."}
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    {adminUser?.role !== "admin" && (
      <section class="panel">
        <p>This action requires an admin account and is hidden from editor-only roles.</p>
      </section>
    )}
  </AdminLayout>
)}

<style>
  .edit-form {
    display: grid;
    gap: 1rem;
  }

  .field-note {
    color: var(--muted);
    margin: 0;
  }

  .editor-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.85rem;
  }

  .field-note a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: none;
  }

  .editor-links a:hover,
  .field-note a:hover {
    text-decoration: underline;
  }

  .translation-inline-form {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .translation-inline-form label {
    display: grid;
    gap: 0.45rem;
  }

  .translation-inline-form button {
    justify-self: start;
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .code-field {
    font-family: monospace;
  }
</style>
