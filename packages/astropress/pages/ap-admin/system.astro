---
import AdminLayout from "astropress/components/AdminLayout.astro";
import CsrfInput from "astropress/components/CsrfInput.astro";
import { buildSystemPageModel } from "astropress";

const adminUser = Astro.locals.adminUser;
const model = await buildSystemPageModel(Astro.locals, adminUser!.role);
const { routeMap } = model.data;
if (model.status === "forbidden") {
  Astro.response.status = 403;
}
const errorMessage = Astro.url.searchParams.get("error") === "1" ? Astro.url.searchParams.get("message") : "";
const wasSaved = Astro.url.searchParams.get("saved") === "1";

const errorPage = routeMap.get("/500");
const robotsPage = routeMap.get("/robots.txt");
const sitemapPage = routeMap.get("/sitemap.xml");
---

{model.status !== "forbidden" ? (
  <AdminLayout
    title="System | Astropress Admin"
    heading="System"
    currentPath="/ap-admin/system"
    description="Admin-owned system routes and generated public outputs."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    {model.warnings.length > 0 && <p class="notice">Some system-route data is temporarily unavailable. This page is showing partial results.</p>}
    <div class="toolbar">
      <a href="/ap-admin/pages" class="admin-button-secondary">Back to pages</a>
      <a href="/500" target="_blank" rel="noreferrer" class="admin-button-ghost">Open 500 page</a>
      <a href="/robots.txt" target="_blank" rel="noreferrer" class="admin-button-ghost">Open robots.txt</a>
      <a href="/sitemap.xml" target="_blank" rel="noreferrer" class="admin-button-ghost">Open sitemap.xml</a>
    </div>
    {wasSaved && <p class="notice">System route updated successfully.</p>}
    {errorMessage && <p class="error-notice">{errorMessage}</p>}

    <section class="panel system-section">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Error Surface</p>
          <h2>500 Page</h2>
          <p>Editor-owned content and CTA settings for the public error page.</p>
        </div>
      </div>
      <form method="post" action="/ap-admin/actions/system-route-save" class="system-form">
        <CsrfInput token={Astro.locals.csrfToken} />
        <input type="hidden" name="path" value="/500" />
        <p class="field-note">Public route: <a href="/500" target="_blank" rel="noreferrer">/500</a></p>
        <label class="admin-field">
          <span>Title</span>
          <input class="admin-input" type="text" name="title" value={errorPage?.title ?? "Request could not be completed"} required />
        </label>
        <label class="admin-field">
          <span>Summary</span>
          <input class="admin-input" type="text" name="summary" value={errorPage?.summary ?? ""} />
        </label>
        <label class="admin-field">
          <span>Body</span>
          <textarea class="admin-textarea" name="bodyHtml" rows="4">{errorPage?.bodyHtml ?? ""}</textarea>
        </label>
        <label class="admin-field">
          <span>Button label</span>
          <input class="admin-input" type="text" name="buttonLabel" value={String(errorPage?.settings?.buttonLabel ?? "Go to homepage")} required />
        </label>
        <label class="admin-field">
          <span>Button href</span>
          <input class="admin-input" type="text" name="buttonHref" value={String(errorPage?.settings?.buttonHref ?? "/")} required />
        </label>
        <label class="admin-field">
          <span>Contact href</span>
          <input class="admin-input" type="text" name="contactHref" value={String(errorPage?.settings?.contactHref ?? "/en/contact")} required />
        </label>
        <label class="admin-field">
          <span>Revision note</span>
          <input class="admin-input" type="text" name="revisionNote" placeholder="Summarize this change" />
        </label>
        <button type="submit" class="admin-button">Save 500 page</button>
      </form>
    </section>

    <section class="panel system-section">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Crawler Output</p>
          <h2>robots.txt</h2>
          <p>Managed generated output for crawler rules and sitemap discovery.</p>
        </div>
      </div>
      <form method="post" action="/ap-admin/actions/system-route-save" class="system-form">
        <CsrfInput token={Astro.locals.csrfToken} />
        <input type="hidden" name="path" value="/robots.txt" />
        <p class="field-note">Generated public output: <a href="/robots.txt" target="_blank" rel="noreferrer">/robots.txt</a></p>
        <label class="admin-field">
          <span>Title</span>
          <input class="admin-input" type="text" name="title" value={robotsPage?.title ?? "Robots"} required />
        </label>
        <label class="admin-field">
          <span>Body</span>
          <textarea class="admin-textarea code-textarea" name="bodyHtml" rows="8">{robotsPage?.bodyHtml ?? ""}</textarea>
        </label>
        <label class="admin-field">
          <span>Revision note</span>
          <input class="admin-input" type="text" name="revisionNote" placeholder="Summarize this change" />
        </label>
        <button type="submit" class="admin-button">Save robots.txt</button>
      </form>
    </section>

    <section class="panel system-section">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Generated Sitemap</p>
          <h2>sitemap.xml</h2>
          <p>Control exclusions and extra canonical URLs for the generated sitemap.</p>
        </div>
      </div>
      <form method="post" action="/ap-admin/actions/system-route-save" class="system-form">
        <CsrfInput token={Astro.locals.csrfToken} />
        <input type="hidden" name="path" value="/sitemap.xml" />
        <p class="field-note">Generated public output: <a href="/sitemap.xml" target="_blank" rel="noreferrer">/sitemap.xml</a></p>
        <label class="admin-field">
          <span>Title</span>
          <input class="admin-input" type="text" name="title" value={sitemapPage?.title ?? "Sitemap"} required />
        </label>
        <label class="admin-field">
          <span>Excluded paths</span>
          <textarea class="admin-textarea code-textarea" name="excludedPaths" rows="4" placeholder="/draft-page&#10;/legacy-path">{Array.isArray(sitemapPage?.settings?.excludedPaths) ? (sitemapPage?.settings?.excludedPaths as string[]).join("\n") : ""}</textarea>
        </label>
        <label class="admin-field">
          <span>Extra canonical URLs</span>
          <textarea class="admin-textarea code-textarea" name="extraUrls" rows="4" placeholder="https://example.com/custom-url/">{Array.isArray(sitemapPage?.settings?.extraUrls) ? (sitemapPage?.settings?.extraUrls as string[]).join("\n") : ""}</textarea>
        </label>
        <label class="admin-field">
          <span>Revision note</span>
          <input class="admin-input" type="text" name="revisionNote" placeholder="Summarize this change" />
        </label>
        <button type="submit" class="admin-button">Save sitemap.xml</button>
      </form>
    </section>
  </AdminLayout>
) : (
  <AdminLayout
    title="Forbidden | Astropress Admin"
    heading="Forbidden"
    currentPath=""
    description="This action requires an admin account."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    <section class="panel forbidden">
      <p>This action requires an admin account and is hidden from editor-only roles.</p>
    </section>
  </AdminLayout>
)}

<style>
  .system-section + .system-section {
    margin-top: 1rem;
  }

  .system-form {
    display: grid;
    gap: 0.9rem;
  }

  button.admin-button {
    width: fit-content;
  }

  .code-textarea {
    font-family: monospace;
  }

  .field-note a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: none;
  }

  .field-note a:hover {
    text-decoration: underline;
  }

  .field-note {
    margin: 0;
    color: var(--muted);
  }
</style>
