---
import AdminLayout from "astropress/components/AdminLayout.astro";
import CsrfInput from "astropress/components/CsrfInput.astro";
import { buildSettingsPageModel } from "astropress";

const adminUser = Astro.locals.adminUser;
const model = await buildSettingsPageModel(Astro.locals, adminUser!.role);
const { settings } = model.data;
const wasSaved = Astro.url.searchParams.get("saved") === "1";
const errorMessage = Astro.url.searchParams.get("error") === "1" ? Astro.url.searchParams.get("message") : "";

if (model.status === "forbidden") {
  Astro.response.status = 403;
}
---

{model.status !== "forbidden" ? (
  <AdminLayout
    title="Settings | Astropress Admin"
    heading="Settings"
    currentPath="/ap-admin/settings"
    description="Configure site-wide settings for content, donations, and engagement."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    {model.warnings.length > 0 && <p class="notice">Settings could not be fully loaded. This page is showing safe fallback values.</p>}
    {wasSaved && <p class="notice">Settings saved successfully.</p>}
    {errorMessage && <p class="error-notice">{errorMessage}</p>}

    <form method="post" action="/ap-admin/actions/settings-save" class="settings-form">
      <CsrfInput token={Astro.locals.csrfToken} />

      <div class="admin-subgrid two summary-grid">
        <section class="panel stat summary-card">
          <span>Donation destination</span>
          <strong>1</strong>
          <span>Primary site-wide donation URL configured here.</span>
        </section>
        <section class="panel stat summary-card">
          <span>Newsletter state</span>
          <strong>{settings.newsletterEnabled ? "On" : "Off"}</strong>
          <span>Controls newsletter collection across public signup surfaces.</span>
        </section>
      </div>

      <section class="panel settings-section">
        <div class="section-header">
          <div>
            <p class="admin-kicker">Brand</p>
            <h2>Site Identity</h2>
            <p>Global naming and branding copy used across the public site.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>Site title</span>
          <input
            type="text"
            name="siteTitle"
            value={settings.siteTitle}
            required
            aria-label="Site title"
            class="admin-input"
          />
        </label>
        <label class="admin-field">
          <span>Site tagline</span>
          <input
            type="text"
            name="siteTagline"
            value={settings.siteTagline}
            required
            aria-label="Site tagline"
            class="admin-input"
          />
        </label>
      </section>

      <section class="panel settings-section">
        <div class="section-header">
          <div>
            <p class="admin-kicker">Fundraising</p>
            <h2>Donation</h2>
            <p>Primary donation destination used by site-wide calls to action.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>Donation URL</span>
          <input
            type="url"
            name="donationUrl"
            value={settings.donationUrl}
            required
            aria-label="Donation URL"
            class="admin-input"
          />
        </label>
      </section>

      <section class="panel settings-section">
        <div class="section-header">
          <div>
            <p class="admin-kicker">Engagement</p>
            <h2>Newsletter</h2>
            <p>Enable or disable newsletter collection across public signup surfaces.</p>
          </div>
        </div>
        <label class="checkbox-label">
          <input
            type="checkbox"
            name="newsletterEnabled"
            value="1"
            checked={settings.newsletterEnabled}
            aria-label="Enable newsletter signup"
          />
          <span>Enable newsletter signup</span>
        </label>
      </section>

      <section class="panel settings-section">
        <div class="section-header">
          <div>
            <p class="admin-kicker">Moderation</p>
            <h2>Comments</h2>
            <p>Default moderation policy for new or imported content records.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>Default comment policy</span>
          <select name="commentsDefaultPolicy" required aria-label="Default comment policy" class="admin-select">
            <option value="disabled" selected={settings.commentsDefaultPolicy === "disabled"}>Disabled</option>
            <option value="legacy-readonly" selected={settings.commentsDefaultPolicy === "legacy-readonly"}>Legacy (read-only)</option>
            <option value="open-moderated" selected={settings.commentsDefaultPolicy === "open-moderated"}>Open (moderated)</option>
          </select>
        </label>
      </section>

      <div class="actions admin-actions-row">
        <button type="submit" class="admin-button">Save settings</button>
      </div>
    </form>
  </AdminLayout>
) : (
  <AdminLayout
    title="Forbidden | Astropress Admin"
    heading="Forbidden"
    currentPath=""
    description="This action requires an admin account."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    <section class="panel forbidden">
      <p>This action requires an admin account and is hidden from editor-only roles.</p>
    </section>
  </AdminLayout>
)}

<style>
  .settings-form {
    display: grid;
    gap: 1rem;
  }

  .summary-grid {
    margin-bottom: 0.25rem;
  }

  .summary-card span:first-child {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 700;
  }

  .summary-card span:last-child {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .settings-section {
    display: grid;
    gap: 1rem;
  }

  .settings-section h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
  }

  input[type="checkbox"] {
    width: 1.2rem;
    height: 1.2rem;
    cursor: pointer;
  }

  .checkbox-label span {
    font-weight: normal;
  }

  .actions {
    margin-top: 1rem;
  }

  .forbidden {
    max-width: 42rem;
  }
</style>
