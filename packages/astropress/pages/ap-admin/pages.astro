---
import AdminLayout from "@astropress-diy/astropress/components/AdminLayout.astro";
import { buildPagesIndexPageModel } from "astropress";
import { isSeededPostRecord } from "astropress";

const adminUser = Astro.locals.adminUser;
const model = await buildPagesIndexPageModel(Astro.locals, adminUser!.role);
const { contentStates, routePages, archiveRows } = model.data;

if (model.status === "forbidden") {
  Astro.response.status = 403;
}

const searchQuery = Astro.url.searchParams.get("q")?.trim().toLowerCase() ?? "";
const selectedKind = Astro.url.searchParams.get("kind") ?? "all";

const legacyPages = contentStates
  .filter((record) => !isSeededPostRecord(record))
  .map((record) => ({
    title: record.title,
    path: record.legacyUrl,
    kind: "Legacy",
    status: record.status ?? "published",
    updatedAt: record.updatedAt,
    editHref: `/ap-admin/posts/${record.slug}`,
    publicHref: record.legacyUrl,
    ownerLabel: "Edit page",
  }));

const structuredPages = routePages.map((page) => ({
  title: page.title,
  path: page.path,
  kind: "Structured",
  status: "published",
  updatedAt: page.updatedAt,
  editHref: `/ap-admin/route-pages${page.path}`,
  publicHref: page.path,
  ownerLabel: "Edit route page",
}));

const archivePages = archiveRows.map(({ archive, runtime }) => ({
  title: runtime?.title ?? archive.title,
  path: archive.legacyUrl,
  kind: "Archive",
  status: "published",
  updatedAt: runtime?.updatedAt,
  editHref: `/ap-admin/archives/${archive.slug}`,
  publicHref: archive.legacyUrl,
  ownerLabel: "Edit archive",
}));

const rows = [...legacyPages, ...structuredPages, ...archivePages].sort((left, right) => left.path.localeCompare(right.path));
const filteredRows = rows.filter((row) => {
  const matchesKind = selectedKind === "all" || row.kind.toLowerCase() === selectedKind;
  const haystack = `${row.title} ${row.path} ${row.kind}`.toLowerCase();
  const matchesSearch = !searchQuery || haystack.includes(searchQuery);
  return matchesKind && matchesSearch;
});
const kindCounts = rows.reduce<Record<string, number>>((accumulator, row) => {
  accumulator[row.kind] = (accumulator[row.kind] ?? 0) + 1;
  return accumulator;
}, {});
const structuredExplanation = "Structured pages are route-backed pages assembled from reusable content sections instead of one imported HTML body. They power pages like home, about, donate, and service landing pages.";
---

{model.status !== "forbidden" ? (
  <AdminLayout
    title="Pages"
    heading="Pages"
    currentPath="/ap-admin/pages"
    description="All human-facing public pages that are not blog posts."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    {model.warnings.length > 0 && <p class="notice">Some page index data is temporarily unavailable. This page is showing partial results.</p>}
    <div class="toolbar">
      <a href="/ap-admin/pages/new" class="admin-button">New page</a>
      <a href="/ap-admin/route-pages" class="admin-button-secondary">Open route table</a>
    </div>
    <div class="admin-subgrid two summary-grid">
      <section class="panel stat summary-card">
        <span>All pages</span>
        <strong>{rows.length}</strong>
        <span>Public HTML pages currently managed through admin.</span>
      </section>
      <section class="panel stat summary-card">
        <span>Structured pages</span>
        <strong>{kindCounts.Structured ?? 0}</strong>
        <span>Route-backed pages that use the structured page system.</span>
      </section>
    </div>
    <section class="panel page-index-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Public Page Ownership</p>
          <h2>Page Index</h2>
          <p>Use this index to manage public pages. Open Route Table only when you need technical route details.</p>
        </div>
      </div>
      <div class="page-notes">
        <div class="note-card">
          <strong>Structured pages</strong>
          <p>{structuredExplanation}</p>
        </div>
        <div class="note-card">
          <strong>Page types in this list</strong>
          <p><strong>Legacy</strong> pages come from imported content. <strong>Structured</strong> pages use reusable sections. <strong>Archive</strong> pages are listing routes such as author, category, and tag archives.</p>
        </div>
      </div>
      <div class="list-toolbar">
        <p><strong>{filteredRows.length} of {rows.length} public pages</strong></p>
        <form method="get" class="filter-form">
          <label>
            <span class="sr-only">Search pages</span>
            <input class="admin-input" type="search" name="q" value={Astro.url.searchParams.get("q") ?? ""} placeholder="Search title or path" aria-label="Search pages" />
          </label>
          <label>
            <span class="sr-only">Filter by page kind</span>
            <select class="admin-select" name="kind" aria-label="Filter pages by kind">
              <option value="all" selected={selectedKind === "all"}>All kinds</option>
              <option value="legacy" selected={selectedKind === "legacy"}>Legacy</option>
              <option value="structured" selected={selectedKind === "structured"}>Structured</option>
              <option value="archive" selected={selectedKind === "archive"}>Archive</option>
            </select>
          </label>
          <button type="submit" class="admin-button">Apply filters</button>
        </form>
      </div>
      <div class="admin-table-shell">
        <table aria-label="Pages list">
          <thead>
            <tr>
              <th>Title</th>
              <th>Path</th>
              <th>Kind</th>
              <th>Status</th>
              <th>Updated</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {filteredRows.length === 0 && (
              <tr><td colspan="2" class="admin-empty-state">No pages match the current filters. <a href="/ap-admin/pages">Clear filters</a> or <a href="/ap-admin/pages/new">create a new page</a>.</td></tr>
            )}
            {filteredRows.map((row) => (
              <tr>
                <td>
                  <div class="page-title-cell">
                    <strong>{row.title}</strong>
                    <code>{row.path}</code>
                  </div>
                </td>
                <td><code>{row.path}</code></td>
                <td><span class={`kind-chip kind-${row.kind.toLowerCase()}`}>{row.kind}</span></td>
                <td><span class={`status-chip status-${row.status.toLowerCase().replace(/\s+/g, "-")}`}>{row.status}</span></td>
                <td>{row.updatedAt ? new Date(row.updatedAt).toLocaleString() : "Seeded"}</td>
                <td>
                  <div class="row-actions">
                    <a href={row.editHref} class="admin-button-ghost small">{row.ownerLabel}</a>
                    <a href={row.publicHref} target="_blank" rel="noreferrer" class="admin-button-ghost small">Open page</a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </AdminLayout>
) : (
  <AdminLayout
    title="Forbidden"
    heading="Forbidden"
    currentPath="/ap-admin/posts"
    description="This action requires an admin account."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    <section class="panel">
      <p>This action requires an admin account and is hidden from editor-only roles.</p>
    </section>
  </AdminLayout>
)}

<style>
  .summary-grid {
    margin-bottom: 1rem;
  }

  .summary-card span:first-child {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 700;
  }

  .summary-card span:last-child {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .page-index-panel {
    display: grid;
    gap: 1rem;
  }

  .list-toolbar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .page-notes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 0.85rem;
    margin-bottom: 1rem;
  }

  .note-card {
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1rem;
    background: color-mix(in srgb, var(--panel) 94%, var(--accent-soft) 6%);
  }

  .note-card strong {
    display: block;
    margin-bottom: 0.35rem;
  }

  .note-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.5;
  }

  .filter-form {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .filter-form input,
  .filter-form select,
  .filter-form button {
    font: inherit;
    border-radius: 0.7rem;
    border: 1px solid var(--line);
    padding: 0.65rem 0.8rem;
  }

  .page-title-cell {
    display: grid;
    gap: 0.25rem;
  }

  .page-title-cell code {
    color: var(--muted);
    font-size: 0.84rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .kind-chip {
    display: inline-flex;
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    font-size: 0.8rem;
    font-weight: 700;
    background: var(--accent-soft);
    color: var(--accent);
  }

  .status-chip {
    display: inline-flex;
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    font-size: 0.8rem;
    font-weight: 700;
    background: var(--bg);
    color: var(--text);
  }

  .status-published {
    background: #e7f5eb;
    color: #14532d;
  }

  .status-review,
  .status-draft {
    background: #fff1cf;
    color: #8a6116;
  }

  .status-archived {
    background: #eceff3;
    color: #52606d;
  }

  .row-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .row-actions a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: none;
  }

  .row-actions a:hover {
    text-decoration: underline;
  }
</style>
