---
import AdminLayout from "astropress/components/AdminLayout.astro";
import { createListmonkOps } from "astropress/newsletter-adapter";
import { getNewsletterConfig } from "astropress/runtime-env";

const adminUser = Astro.locals.adminUser;

if (!adminUser || adminUser.role !== "admin") {
  Astro.response.status = 403;
}

const { id } = Astro.params as { id: string };

interface SubscriberDetail {
  id: string | number;
  email: string;
  name: string;
  status: string;
  createdAt: string;
}

let subscriber: SubscriberDetail | null = null;
let listSupported = false;
let errorMessage = "";

if (adminUser?.role === "admin") {
  try {
    const cfg = getNewsletterConfig(Astro.locals);
    if (
      cfg.mode === "listmonk" &&
      cfg.listmonkApiUrl &&
      cfg.listmonkApiUsername &&
      cfg.listmonkApiPassword &&
      cfg.listmonkListId
    ) {
      listSupported = true;
      const ops = createListmonkOps({
        apiUrl: cfg.listmonkApiUrl,
        apiUsername: cfg.listmonkApiUsername,
        apiPassword: cfg.listmonkApiPassword,
        listId: Number(cfg.listmonkListId),
      });
      const result = await ops.getSubscriber(id);
      subscriber = result.subscriber as SubscriberDetail;
    }
  } catch (e) {
    errorMessage = "Could not load subscriber. The subscriber may not exist, or your LISTMONK_* environment variables may be misconfigured.";
  }
}

const wasDeleted = Astro.url.searchParams.get("deleted") === "1";
---

{adminUser?.role === "admin" ? (
  <AdminLayout
    title={subscriber ? `${subscriber.email} — Subscribers — Astropress Admin` : "Subscriber — Astropress Admin"}
    heading={subscriber ? subscriber.email : "Subscriber"}
    description="View and manage this newsletter subscriber."
    role={adminUser.role}
    userName={adminUser.name}
    currentPath="/ap-admin/subscribers"
  >
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/ap-admin/subscribers">Subscribers</a>
      <span aria-hidden="true"> / </span>
      <span aria-current="page">{subscriber ? subscriber.email : id}</span>
    </nav>

    {wasDeleted && <p class="notice">Subscriber removed successfully.</p>}
    {errorMessage && <p class="error-notice">{errorMessage}</p>}

    {!listSupported && !errorMessage && (
      <div class="notice">
        <p>Subscriber details require Listmonk. Configure the <code>LISTMONK_*</code> environment variables to enable it.</p>
      </div>
    )}

    {listSupported && subscriber && (
      <div class="subscriber-detail">
        <div class="detail-card">
          <dl class="detail-list">
            <div class="detail-row">
              <dt>Email</dt>
              <dd class="detail-email">{subscriber.email}</dd>
            </div>
            <div class="detail-row">
              <dt>Name</dt>
              <dd>{subscriber.name || <span class="muted">—</span>}</dd>
            </div>
            <div class="detail-row">
              <dt>Status</dt>
              <dd>
                <span class={`status-badge status-badge--${subscriber.status}`}>{subscriber.status}</span>
              </dd>
            </div>
            <div class="detail-row">
              <dt>Subscribed</dt>
              <dd class="muted">
                {subscriber.createdAt ? new Date(subscriber.createdAt).toLocaleString() : "—"}
              </dd>
            </div>
            <div class="detail-row">
              <dt>Subscriber ID</dt>
              <dd class="muted">{subscriber.id}</dd>
            </div>
          </dl>
        </div>

        <div class="danger-zone">
          <h2 class="danger-zone__title">Remove subscriber</h2>
          <p class="danger-zone__desc">
            This permanently removes the subscriber from Listmonk. This action cannot be undone.
          </p>
          <form
            method="post"
            action="/ap-admin/actions/subscriber-delete"
            class="delete-form"
            data-confirm="Remove this subscriber? This cannot be undone."
          >
            <input type="hidden" name="id" value={String(subscriber.id)} />
            <button type="submit" class="delete-btn">Remove subscriber</button>
          </form>
        </div>
      </div>
    )}

    {listSupported && !subscriber && !errorMessage && (
      <p class="error-notice">Subscriber not found.</p>
    )}

    <style>
      .breadcrumb { font-size: 0.875rem; color: var(--text-muted, #6b7280); margin-bottom: 1.5rem; }
      .breadcrumb a { color: var(--accent, #6366f1); text-decoration: none; }
      .breadcrumb a:hover { text-decoration: underline; }
      .subscriber-detail { max-width: 560px; }
      .detail-card { border: 1px solid var(--border, #e5e7eb); border-radius: 8px; background: var(--surface, #fff); padding: 1.25rem; margin-bottom: 1.5rem; }
      .detail-list { margin: 0; }
      .detail-row { display: flex; gap: 1rem; padding: 0.625rem 0; border-bottom: 1px solid var(--border, #e5e7eb); }
      .detail-row:last-child { border-bottom: none; }
      .detail-row dt { width: 140px; flex-shrink: 0; font-size: 0.875rem; font-weight: 500; color: var(--text-muted, #6b7280); padding-top: 0.0625rem; }
      .detail-row dd { margin: 0; font-size: 0.9375rem; }
      .detail-email { font-weight: 500; word-break: break-all; }
      .muted { color: var(--text-muted, #6b7280); font-size: 0.875rem; }
      .status-badge { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; text-transform: capitalize; background: var(--status-bg, #f3f4f6); }
      .status-badge--enabled, .status-badge--subscribed { background: #dcfce7; color: #166534; }
      .status-badge--disabled, .status-badge--unsubscribed { background: #fee2e2; color: #991b1b; }
      .status-badge--blocklisted { background: #fef3c7; color: #92400e; }
      .danger-zone { border: 1px solid #fca5a5; border-radius: 8px; padding: 1.25rem; background: #fff7f7; }
      .danger-zone__title { margin: 0 0 0.5rem; font-size: 0.9375rem; font-weight: 600; color: #991b1b; }
      .danger-zone__desc { font-size: 0.875rem; color: #6b7280; margin: 0 0 1rem; }
      .delete-btn { padding: 0.5rem 1rem; background: #dc2626; color: #fff; border: none; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer; }
      .delete-btn:hover { background: #b91c1c; }
    </style>
    <script>
      document.querySelectorAll<HTMLFormElement>("form[data-confirm]").forEach((form) => {
        form.addEventListener("submit", (e) => {
          const msg = form.dataset.confirm ?? "Are you sure?";
          if (!window.confirm(msg)) e.preventDefault();
        });
      });
    </script>
  </AdminLayout>
) : (
  <AdminLayout
    title="Forbidden — Astropress Admin"
    heading="Access denied"
    description="You do not have permission to view this page."
    role={adminUser?.role ?? "editor"}
    userName={adminUser?.name ?? ""}
    currentPath="/ap-admin/subscribers"
  >
    <p>Only admin users can access subscriber management.</p>
  </AdminLayout>
)}
