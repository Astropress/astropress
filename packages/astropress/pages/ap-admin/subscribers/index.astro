---
import AdminLayout from "astropress/components/AdminLayout.astro";
import { getCmsConfig } from "astropress";
import { createListmonkOps } from "astropress/newsletter-adapter";
import { getNewsletterConfig } from "astropress/runtime-env";

const adminUser = Astro.locals.adminUser;

if (!adminUser || adminUser.role !== "admin") {
  Astro.response.status = 403;
}

const page = Number(Astro.url.searchParams.get("page") ?? "1");
const query = Astro.url.searchParams.get("q") ?? "";
const perPage = 25;

interface SubscriberRow {
  id: string | number;
  email: string;
  name: string;
  status: string;
  createdAt: string;
}

let subscribers: SubscriberRow[] = [];
let total = 0;
let listSupported = false;
let errorMessage = "";

try {
  const cfg = getNewsletterConfig(Astro.locals);
  if (
    cfg.mode === "listmonk" &&
    cfg.listmonkApiUrl &&
    cfg.listmonkApiUsername &&
    cfg.listmonkApiPassword &&
    cfg.listmonkListId
  ) {
    listSupported = true;
    const ops = createListmonkOps({
      apiUrl: cfg.listmonkApiUrl,
      apiUsername: cfg.listmonkApiUsername,
      apiPassword: cfg.listmonkApiPassword,
      listId: Number(cfg.listmonkListId),
    });
    const result = await ops.listSubscribers({ page, perPage, query });
    subscribers = result.subscribers as SubscriberRow[];
    total = result.total;
  }
} catch (e) {
  errorMessage = "Could not load subscriber list. Check your LISTMONK_* environment variables.";
}

const totalPages = Math.ceil(total / perPage);
const prevPage = page > 1 ? page - 1 : null;
const nextPage = page < totalPages ? page + 1 : null;

const wasDeleted = Astro.url.searchParams.get("deleted") === "1";
---

{adminUser?.role === "admin" ? (
  <AdminLayout
    title="Subscribers — Astropress Admin"
    heading="Subscribers"
    description="Manage newsletter subscribers."
    role={adminUser.role}
    userName={adminUser.name}
    currentPath="/ap-admin/subscribers"
  >
    {wasDeleted && <p class="notice">Subscriber removed successfully.</p>}
    {errorMessage && <p class="error-notice">{errorMessage}</p>}

    {!listSupported && !errorMessage && (
      <div class="notice">
        <p>Subscriber list management requires Listmonk. Configure these environment variables to enable it:</p>
        <ul>
          <li><code>NEWSLETTER_DELIVERY=listmonk</code></li>
          <li><code>LISTMONK_API_URL</code> — e.g. <code>http://localhost:9000</code></li>
          <li><code>LISTMONK_API_USERNAME</code></li>
          <li><code>LISTMONK_API_PASSWORD</code></li>
          <li><code>LISTMONK_LIST_ID</code></li>
        </ul>
      </div>
    )}

    {listSupported && (
      <div class="subscribers-panel">
        <form method="get" action="/ap-admin/subscribers" class="search-form" role="search">
          <label for="sub-search" class="visually-hidden">Search subscribers</label>
          <input
            id="sub-search"
            type="search"
            name="q"
            value={query}
            placeholder="Search by email or name&hellip;"
            class="search-input"
            autocomplete="off"
          />
          <button type="submit" class="search-btn">Search</button>
          {query && <a href="/ap-admin/subscribers" class="clear-btn">Clear</a>}
        </form>

        <p class="sub-count">
          {total === 0 ? "No subscribers found." : `${total} subscriber${total === 1 ? "" : "s"}`}
          {query ? ` matching "${query}"` : ""}
        </p>

        {subscribers.length > 0 && (
          <table class="sub-table">
            <thead>
              <tr>
                <th scope="col">Email</th>
                <th scope="col">Name</th>
                <th scope="col">Status</th>
                <th scope="col">Subscribed</th>
                <th scope="col"><span class="visually-hidden">Actions</span></th>
              </tr>
            </thead>
            <tbody>
              {subscribers.map((sub) => (
                <tr>
                  <td class="email-cell">{sub.email}</td>
                  <td>{sub.name || "—"}</td>
                  <td>
                    <span class={`status-badge status-badge--${sub.status}`}>{sub.status}</span>
                  </td>
                  <td class="date-cell">{sub.createdAt ? new Date(sub.createdAt).toLocaleDateString() : "—"}</td>
                  <td class="actions-cell">
                    <a href={`/ap-admin/subscribers/${sub.id}`} class="action-link">View</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        {totalPages > 1 && (
          <nav class="pagination" aria-label="Subscriber pages">
            {prevPage ? (
              <a href={`/ap-admin/subscribers?page=${prevPage}${query ? `&q=${encodeURIComponent(query)}` : ""}`} rel="prev" class="page-link">&larr; Previous</a>
            ) : <span class="page-link page-link--disabled">&larr; Previous</span>}
            <span class="page-info">Page {page} of {totalPages}</span>
            {nextPage ? (
              <a href={`/ap-admin/subscribers?page=${nextPage}${query ? `&q=${encodeURIComponent(query)}` : ""}`} rel="next" class="page-link">Next &rarr;</a>
            ) : <span class="page-link page-link--disabled">Next &rarr;</span>}
          </nav>
        )}
      </div>
    )}

    <style>
      .subscribers-panel { margin-top: 1rem; }
      .search-form { display: flex; gap: 0.5rem; margin-bottom: 1rem; align-items: center; }
      .search-input { flex: 1; max-width: 360px; padding: 0.5rem 0.75rem; border: 1px solid var(--border, #e5e7eb); border-radius: 6px; font-size: 0.9375rem; }
      .search-btn, .clear-btn { padding: 0.5rem 0.875rem; border: 1px solid var(--border, #e5e7eb); border-radius: 6px; font-size: 0.875rem; cursor: pointer; background: var(--surface, #fff); text-decoration: none; }
      .search-btn { background: var(--accent, #6366f1); color: #fff; border-color: var(--accent, #6366f1); }
      .sub-count { font-size: 0.875rem; color: var(--text-muted, #6b7280); margin-bottom: 0.75rem; }
      .sub-table { width: 100%; border-collapse: collapse; font-size: 0.9375rem; }
      .sub-table th { text-align: left; padding: 0.5rem 0.75rem; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted, #6b7280); border-bottom: 2px solid var(--border, #e5e7eb); }
      .sub-table td { padding: 0.625rem 0.75rem; border-bottom: 1px solid var(--border, #e5e7eb); vertical-align: middle; }
      .email-cell { font-weight: 500; }
      .date-cell { color: var(--text-muted, #6b7280); font-size: 0.875rem; }
      .actions-cell { text-align: right; }
      .action-link { font-size: 0.875rem; color: var(--accent, #6366f1); text-decoration: none; }
      .status-badge { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; text-transform: capitalize; background: var(--status-bg, #f3f4f6); }
      .status-badge--enabled, .status-badge--subscribed { background: #dcfce7; color: #166534; }
      .status-badge--disabled, .status-badge--unsubscribed { background: #fee2e2; color: #991b1b; }
      .status-badge--blocklisted { background: #fef3c7; color: #92400e; }
      .pagination { display: flex; align-items: center; gap: 1rem; margin-top: 1.25rem; font-size: 0.9375rem; }
      .page-link { color: var(--accent, #6366f1); text-decoration: none; }
      .page-link--disabled { color: var(--text-muted, #6b7280); cursor: default; }
      .page-info { color: var(--text-muted, #6b7280); }
      .visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
    </style>
  </AdminLayout>
) : (
  <AdminLayout
    title="Forbidden — Astropress Admin"
    heading="Access denied"
    description="You do not have permission to view this page."
    role={adminUser?.role ?? "editor"}
    userName={adminUser?.name ?? ""}
    currentPath="/ap-admin/subscribers"
  >
    <p>Only admin users can access subscriber management.</p>
  </AdminLayout>
)}
