---
import AdminLayout from "@astropress-diy/astropress/components/AdminLayout.astro";
import { buildPostsIndexPageModel } from "astropress";
import { isSeededPostRecord } from "astropress";

const adminUser = Astro.locals.adminUser;

if (Astro.url.searchParams.get("type") === "page") {
  return Astro.redirect("/ap-admin/pages", 302);
}

const model = await buildPostsIndexPageModel(Astro.locals);
const { authors, categories, tags, allContent, archives } = model.data;

const rows = allContent.filter((record) => isSeededPostRecord(record));

const query = Astro.url.searchParams;
const statusFilter = query.get("status")?.trim() || "";
const workflowFilter = query.get("workflow")?.trim() || "";
const archiveFilter = query.get("archive")?.trim() || "";
const authorFilter = Number(query.get("author") ?? "");
const categoryFilter = Number(query.get("category") ?? "");
const tagFilter = Number(query.get("tag") ?? "");
const searchFilter = query.get("q")?.trim().toLowerCase() || "";
const now = Date.now();

const authorNamesById = new Map(authors.map((author) => [author.id, author.name]));
const categoryNamesById = new Map(categories.map((term) => [term.id, term.name]));
const tagNamesById = new Map(tags.map((term) => [term.id, term.name]));
const selectedArchive = archives.find((entry) => entry.slug === archiveFilter) ?? null;
const selectedArchiveRoutes = new Set((selectedArchive?.listingItems ?? []).map((item) => item.href));

function joinAssignmentLabels(ids: number[] | undefined, labelsById: Map<number, string>) {
  if (!ids || ids.length === 0) {
    return "—";
  }

  const labels = ids.map((id) => labelsById.get(id)).filter((value): value is string => Boolean(value));
  return labels.length > 0 ? labels.join(", ") : "—";
}

function formatScheduledAt(value: string | undefined) {
  if (!value) {
    return "—";
  }

  return new Date(value).toLocaleString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "numeric",
    minute: "2-digit",
  });
}

function getWorkflowLabel(state: (typeof rows)[number]) {
  const effectiveStatus = state.status || "published";
  const scheduledAt = state.scheduledAt;
  const scheduledMs = scheduledAt ? Date.parse(scheduledAt) : NaN;

  if (scheduledAt && Number.isFinite(scheduledMs) && scheduledMs > now) {
    return "scheduled";
  }

  if (effectiveStatus === "review" || effectiveStatus === "draft") {
    return "review-needed";
  }

  if (!scheduledAt) {
    return "unscheduled";
  }

  return "scheduled";
}

const PAGE_SIZE = 25;
const currentPage = Math.max(Number(query.get("page") ?? "1") || 1, 1);

const filteredRows = rows.filter((page) => {
  const effectiveStatus = page.status || "published";
  const authorIds = page.authorIds ?? [];
  const categoryIds = page.categoryIds ?? [];
  const tagIds = page.tagIds ?? [];
  const workflowLabel = getWorkflowLabel(page);
  const matchesArchive =
    !archiveFilter ||
    selectedArchiveRoutes.size === 0 ||
    selectedArchiveRoutes.has(page.legacyUrl);
  const matchesSearch =
    searchFilter.length === 0 ||
    [
      page.title,
      page.slug,
      page.legacyUrl,
      joinAssignmentLabels(authorIds, authorNamesById),
      joinAssignmentLabels(categoryIds, categoryNamesById),
      joinAssignmentLabels(tagIds, tagNamesById),
      formatScheduledAt(page.scheduledAt),
      workflowLabel,
    ]
      .join(" ")
      .toLowerCase()
      .includes(searchFilter);

  return (
    (!statusFilter || effectiveStatus === statusFilter) &&
    (!workflowFilter || workflowLabel === workflowFilter) &&
    matchesArchive &&
    (!Number.isInteger(authorFilter) || authorFilter <= 0 || authorIds.includes(authorFilter)) &&
    (!Number.isInteger(categoryFilter) || categoryFilter <= 0 || categoryIds.includes(categoryFilter)) &&
    (!Number.isInteger(tagFilter) || tagFilter <= 0 || tagIds.includes(tagFilter)) &&
    matchesSearch
  );
});

const totalPages = Math.max(Math.ceil(filteredRows.length / PAGE_SIZE), 1);
const safePage = Math.min(currentPage, totalPages);
const pagedRows = filteredRows.slice((safePage - 1) * PAGE_SIZE, safePage * PAGE_SIZE);

function paginationHref(targetPage: number) {
  const p = new URLSearchParams(query);
  p.set("page", String(targetPage));
  return `/ap-admin/posts?${p.toString()}`;
}
---

<AdminLayout
  title="Posts"
  heading="Posts"
  currentPath="/ap-admin/posts"
  description="Published and draft blog posts managed through the post editor."
  role={adminUser!.role}
  userName={adminUser!.name}
>
  {model.warnings.length > 0 && <p class="notice">Some post index data is temporarily unavailable. This page is showing partial results.</p>}
  <div class="toolbar">
    <a href="/ap-admin/posts/new" class="admin-button">New post</a>
    <a href="/blog" class="admin-button-secondary">Open public blog</a>
  </div>
  <div class="admin-subgrid two summary-grid">
    <section class="panel stat summary-card">
      <span>Visible posts</span>
      <strong>{filteredRows.length}</strong>
      <span>Posts in the current filtered view.</span>
    </section>
    <section class="panel stat summary-card">
      <span>Review queue</span>
      <strong>{rows.filter((record) => (record.status ?? "published") === "review" || (record.status ?? "published") === "draft").length}</strong>
      <span>Draft and in-review posts waiting for editorial work.</span>
    </section>
  </div>
  <section class="panel post-search-panel">
      <div class="section-header">
      <div>
        <p class="admin-kicker">Post Workflow</p>
        <h2>Blog Post List</h2>
        <p>Search once, then narrow to the exact editorial slice you need.</p>
      </div>
      <div class="filter-shortcuts">
        <a href="/ap-admin/posts?workflow=review-needed" class="admin-button-ghost small">Needs review</a>
        <a href="/ap-admin/posts?workflow=scheduled" class="admin-button-ghost small">Scheduled</a>
        <a href="/ap-admin/posts?status=published" class="admin-button-ghost small">Published</a>
      </div>
    </div>
    <form method="get" class="search-shell" aria-label="Content filters">
      <div class="search-row">
        <label class="search-field">
          <span class="sr-only">Search posts</span>
          <input type="search" name="q" value={searchFilter} placeholder="Search title, slug, route, or assignment" aria-label="Search posts" />
        </label>
        <button type="submit" class="admin-button">Search posts</button>
        <a href="/ap-admin/posts" class="admin-button-ghost">Clear filters</a>
      </div>
      <div class="filters">
        <label>
          <span>Status</span>
          <select name="status">
            <option value="">All statuses</option>
            <option value="published" selected={statusFilter === "published"}>Published</option>
            <option value="review" selected={statusFilter === "review"}>In Review</option>
            <option value="draft" selected={statusFilter === "draft"}>Draft</option>
            <option value="archived" selected={statusFilter === "archived"}>Archived</option>
          </select>
        </label>
        <label>
          <span>Workflow</span>
          <select name="workflow">
            <option value="">All workflow states</option>
            <option value="scheduled" selected={workflowFilter === "scheduled"}>Scheduled</option>
            <option value="review-needed" selected={workflowFilter === "review-needed"}>Needs review</option>
            <option value="unscheduled" selected={workflowFilter === "unscheduled"}>Unscheduled</option>
          </select>
        </label>
        {selectedArchive && <input type="hidden" name="archive" value={selectedArchive.slug} />}
        <label>
          <span>Author</span>
          <select name="author">
            <option value="">All authors</option>
            {authors.map((author) => (
              <option value={author.id} selected={authorFilter === author.id}>{author.name}</option>
            ))}
          </select>
        </label>
        <label>
          <span>Category</span>
          <select name="category">
            <option value="">All categories</option>
            {categories.map((term) => (
              <option value={term.id} selected={categoryFilter === term.id}>{term.name}</option>
            ))}
          </select>
        </label>
        <label>
          <span>Tag</span>
          <select name="tag">
            <option value="">All tags</option>
            {tags.map((term) => (
              <option value={term.id} selected={tagFilter === term.id}>{term.name}</option>
            ))}
          </select>
        </label>
      </div>
    </form>
    {selectedArchive && (
      <p class="field-note">
        Archive filter: <strong>{selectedArchive.title}</strong>
      </p>
    )}
    <p class="field-note">{filteredRows.length} posts matched the current filters. Showing page {safePage} of {totalPages}.</p>
    <div class="admin-table-shell">
      <table aria-label="Content list">
        <thead>
          <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Workflow</th>
            <th>Scheduled</th>
            <th>Authors</th>
            <th>Categories</th>
          </tr>
        </thead>
        <tbody>
          {pagedRows.map((page) => {
            const workflowLabel = getWorkflowLabel(page);
            return (
              <tr>
                <td>
                  <div class="title-cell">
                    <a href={`/ap-admin/posts/${page.slug}`}>{page.title}</a>
                    <span>{page.legacyUrl}</span>
                  </div>
                </td>
                <td>{page.status || "published"}</td>
                <td><span class={`workflow-chip ${workflowLabel}`}>{workflowLabel.replace("-", " ")}</span></td>
                <td>{formatScheduledAt(page.scheduledAt)}</td>
                <td>{joinAssignmentLabels(page.authorIds, authorNamesById)}</td>
                <td>{joinAssignmentLabels(page.categoryIds, categoryNamesById)}</td>
              </tr>
            );
          })}
          {pagedRows.length === 0 && (
            <tr>
              <td colspan="6">No content records matched the current filters.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
    {totalPages > 1 && (
      <nav aria-label="pagination" class="pagination-nav">
        {safePage > 1
          ? <a href={paginationHref(safePage - 1)} class="admin-button-ghost" rel="prev" aria-label="Previous page">← Previous</a>
          : <span class="admin-button-ghost disabled" aria-disabled="true">← Previous</span>
        }
        <span class="page-counter" aria-current="page">Page {safePage} of {totalPages}</span>
        {safePage < totalPages
          ? <a href={paginationHref(safePage + 1)} class="admin-button-ghost" rel="next" aria-label="Next page">Next →</a>
          : <span class="admin-button-ghost disabled" aria-disabled="true">Next →</span>
        }
      </nav>
    )}
  </section>
</AdminLayout>

<style>
  .summary-grid {
    margin-bottom: 1rem;
  }

  .summary-card span:first-child {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 700;
  }

  .summary-card span:last-child {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .post-search-panel {
    display: grid;
    gap: 1rem;
  }

  .search-shell {
    display: grid;
    gap: 0.9rem;
  }

  .search-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .search-field {
    flex: 1 1 20rem;
  }

  .search-field input {
    width: 100%;
  }

  .filters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 0.9rem;
  }

  .filters label {
    display: grid;
    gap: 0.35rem;
  }

  .filters select,
  .search-field input {
    font: inherit;
    border-radius: 0.85rem;
    border: 1px solid var(--line);
    padding: 0.75rem 0.9rem;
    background: var(--panel);
    color: var(--text);
  }

  .filter-shortcuts {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .filters span,
  .field-note {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .title-cell {
    display: grid;
    gap: 0.18rem;
  }

  .title-cell a {
    color: inherit;
    font-weight: 700;
    text-decoration: none;
  }

  .pagination-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: center;
    padding: 0.75rem 0;
  }

  .page-counter {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .admin-button-ghost.disabled {
    opacity: 0.4;
    cursor: default;
    pointer-events: none;
  }

  .title-cell span {
    color: var(--muted);
    font-size: 0.84rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
</style>
