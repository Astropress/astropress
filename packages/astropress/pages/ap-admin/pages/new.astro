---
import AdminLayout from "@astropress-diy/astropress/components/AdminLayout.astro";
import CsrfInput from "@astropress-diy/astropress/components/CsrfInput.astro";

const adminUser = Astro.locals.adminUser;

if (adminUser?.role !== "admin") {
	Astro.response.status = 403;
}

const errorMessage =
	Astro.url.searchParams.get("error") === "1"
		? Astro.url.searchParams.get("message")
		: "";
---

{adminUser?.role === "admin" ? (
  <AdminLayout
    title="New Page"
    heading="New Page"
    currentPath="/ap-admin/pages"
    description="Create a new public page using the route-backed page model."
    role={adminUser.role}
    userName={adminUser.name}
  >
    {errorMessage && <p class="error-notice">{errorMessage}</p>}

    <form method="post" action="/ap-admin/actions/route-page-create" class="edit-form">
      <CsrfInput token={Astro.locals.csrfToken} />

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>General</h2>
            <p>Create a route-backed public page that will be edited through the Pages workflow.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>Title</span>
          <input type="text" name="title" aria-label="Page title" required class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Public path</span>
          <input type="text" name="path" aria-label="Public path" placeholder="/new-page" required class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Summary</span>
          <textarea name="summary" aria-label="Page summary" rows="3" class="admin-textarea"></textarea>
        </label>
      </section>

      <section class="panel">
        <div class="section-header">
          <div>
            <h2>SEO</h2>
            <p>Add the search-facing metadata you want this page to launch with.</p>
          </div>
        </div>
        <label class="admin-field">
          <span>SEO Title</span>
          <input type="text" name="seoTitle" aria-label="SEO title" required class="admin-input" />
        </label>
        <label class="admin-field">
          <span>Meta Description</span>
          <textarea name="metaDescription" aria-label="Meta description" rows="3" required class="admin-textarea"></textarea>
        </label>
      </section>

      <div class="form-actions">
        <button type="submit" class="admin-button">Create page</button>
        <a href="/ap-admin/pages" class="admin-button-ghost secondary-button">Cancel</a>
      </div>
    </form>
  </AdminLayout>
) : (
  <AdminLayout
    title="Forbidden"
    heading="Forbidden"
    currentPath="/ap-admin/posts"
    description="This action requires an admin account."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    <section class="panel">
      <p>This action requires an admin account and is hidden from editor-only roles.</p>
    </section>
  </AdminLayout>
)}
