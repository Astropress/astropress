---
import AdminLayout from "@astropress-diy/astropress/components/AdminLayout.astro";
import AuditTrail from "@astropress-diy/astropress/components/AuditTrail.astro";
import CsrfInput from "@astropress-diy/astropress/components/CsrfInput.astro";
import { buildUsersPageModel } from "astropress";

const adminUser = Astro.locals.adminUser;
const model = await buildUsersPageModel(Astro.locals, adminUser!.role);
const { users, auditEvents } = model.data;
const wasCreated = Astro.url.searchParams.get("saved") === "1";
const userCreatedNoEmail = Astro.url.searchParams.get("user_created") === "1";
const wasSuspended = Astro.url.searchParams.get("suspended") === "1";
const wasRestored = Astro.url.searchParams.get("restored") === "1";
const inviteLink = Astro.url.searchParams.get("invite_link");
const resetLink = Astro.url.searchParams.get("reset_link");
const errorMessage = Astro.url.searchParams.get("error") === "1" ? Astro.url.searchParams.get("message") : "";

if (model.status === "forbidden") {
  Astro.response.status = 403;
}
---

{model.status !== "forbidden" ? (
  <AdminLayout
    title="Users - Astropress Admin"
    heading="Users"
    description="Manage team members, roles, and access state."
    role={adminUser!.role}
    userName={adminUser!.name}
    currentPath="/ap-admin/users"
  >
    {model.warnings.length > 0 && <p class="notice">Some user-management data is temporarily unavailable. This page is showing partial results.</p>}
    {wasCreated && <p class="notice">The invitation was issued successfully.</p>}
    {userCreatedNoEmail && <p class="notice">User created. Email delivery is in preview mode — no invitation email was sent. Use the link below to share the invite manually.</p>}
    {wasSuspended && <p class="notice">The admin user was suspended successfully.</p>}
    {wasRestored && <p class="notice">The admin user was restored successfully.</p>}
    {inviteLink && <p class="notice">Invitation link: <a href={inviteLink}>{inviteLink}</a></p>}
    {resetLink && <p class="notice">Password reset link issued: <a href={resetLink}>{resetLink}</a></p>}
    {errorMessage && <p class="error-notice">{errorMessage}</p>}
    <div class="notice intro-notice">
      User management is admin-only. New accounts are invited first and set their own password through a single-use link.
    </div>

    <div class="admin-subgrid two summary-grid">
      <section class="panel stat summary-card">
        <span>Total users</span>
        <strong>{users.length}</strong>
        <span>Managed admin and editor accounts.</span>
      </section>
      <section class="panel stat summary-card">
        <span>Pending invites</span>
        <strong>{users.filter((user) => user.status === "invited").length}</strong>
        <span>Invitations that have not been accepted yet.</span>
      </section>
    </div>

    <section class="panel users-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Access Control</p>
          <h2>Current Users</h2>
          <p>Manage roles, suspend access, and issue one-time reset links from the same table.</p>
        </div>
      </div>
      <div class="admin-table-shell">
        <table aria-label="Admin users">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Joined</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {
              users.map((user) => {
                const isSuspended = user.status === "suspended";
                const isInvited = user.status === "invited";
                return (
                  <tr>
                    <td class="strong-cell">{user.name}</td>
                    <td>{user.email}</td>
                    <td>
                      <span class="admin-chip">{user.role}</span>
                    </td>
                    <td class="muted-cell">{user.createdAt.slice(0, 10)}</td>
                    <td>
                      {isSuspended ? (
                        <span class="status-chip suspended">Suspended</span>
                      ) : isInvited ? (
                        <span class="status-chip invited">Invited</span>
                      ) : (
                        <span class="status-chip active">Active</span>
                      )}
                    </td>
                    <td>
                      <div class="user-actions">
                        {isSuspended ? (
                          <form method="post" action="/ap-admin/actions/user-unsuspend" class="admin-inline-form">
                            <CsrfInput token={Astro.locals.csrfToken} />
                            <input type="hidden" name="email" value={user.email} />
                            <button type="submit" class="admin-button small">Unsuspend</button>
                          </form>
                        ) : (
                          <>
                            <form method="post" action="/ap-admin/actions/user-suspend" class="admin-inline-form">
                              <CsrfInput token={Astro.locals.csrfToken} />
                              <input type="hidden" name="email" value={user.email} />
                              <button type="submit" data-confirm="Suspend this user?" class="admin-button-ghost small danger-ghost">Suspend</button>
                            </form>
                            <form method="post" action="/ap-admin/actions/user-reset-link" class="admin-inline-form">
                              <CsrfInput token={Astro.locals.csrfToken} />
                              <input type="hidden" name="email" value={user.email} />
                              <button type="submit" class="admin-button-ghost small">Reset Link</button>
                            </form>
                          </>
                        )}
                      </div>
                    </td>
                  </tr>
                );
              })
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel invite-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Create Access</p>
          <h2>Invite User</h2>
          <p>Invite a team member and let them set their password from a single-use link.</p>
        </div>
      </div>
      <form method="post" action="/ap-admin/actions/user-invite" class="form-grid admin-form-grid columns-3">
        <CsrfInput token={Astro.locals.csrfToken} />
        <div class="form-group admin-field">
          <label for="invite-name">Full Name</label>
          <input type="text" id="invite-name" name="name" required class="admin-input" />
        </div>
        <div class="form-group admin-field">
          <label for="invite-email">Email</label>
          <input type="email" id="invite-email" name="email" required class="admin-input" />
        </div>
        <div class="form-group admin-field">
          <label for="invite-role">Role</label>
          <select id="invite-role" name="role" required class="admin-select">
            <option value="editor">Editor</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="form-group form-actions">
          <button type="submit" class="admin-button">Send Invitation</button>
        </div>
      </form>
      <p class="invite-note">
        The invited user receives a single-use setup link. In non-production mode, the link is echoed above for local review.
      </p>
    </section>

    <AuditTrail
      events={auditEvents.filter((event) => event.action.startsWith("user.") || event.action.startsWith("auth.")).slice(0, 6)}
      heading="User And Access Audit"
    />

    <section class="panel gdpr-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">GDPR / Right of Erasure</p>
          <h2>Purge User Data</h2>
          <p>
            Permanently remove all personal data associated with an email address. This action revokes sessions,
            anonymises audit log entries, deletes comments and contact submissions, and suspends or deletes the
            admin account. A JSON export of all affected records is downloaded for your data-subject-request records.
          </p>
        </div>
      </div>
      <form method="post" action="/ap-admin/actions/user-purge" class="form-grid admin-form-grid columns-3" id="gdpr-purge-form">
        <CsrfInput token={Astro.locals.csrfToken} />
        <div class="form-group admin-field">
          <label for="purge-email">Email address to purge</label>
          <input type="email" id="purge-email" name="email" required class="admin-input" />
        </div>
        <div class="form-group admin-field admin-field--checkbox">
          <label>
            <input type="checkbox" name="deleteAccount" value="1" />
            Permanently delete admin account (instead of suspending)
          </label>
        </div>
        <div class="form-group form-actions">
          <button type="submit" class="admin-button danger" data-confirm="This will permanently erase all personal data for this email. This cannot be undone. Continue?">
            Purge &amp; Download Report
          </button>
        </div>
      </form>
    </section>
  </AdminLayout>
) : (
  <AdminLayout
    title="Forbidden | Astropress Admin"
    heading="Forbidden"
    currentPath=""
    description="This action requires an admin account."
    role={adminUser!.role}
    userName={adminUser!.name}
  >
    <section class="panel forbidden">
      <p>This action requires an admin account and is hidden from editor-only roles.</p>
    </section>
  </AdminLayout>
)}

<style>
  .intro-notice,
  .summary-grid,
  .users-panel {
    margin-bottom: 1rem;
  }

  .summary-card span:first-child {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 700;
  }

  .summary-card span:last-child,
  .invite-note {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .users-panel,
  .invite-panel {
    display: grid;
    gap: 1rem;
  }

  .form-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .forbidden {
    max-width: 42rem;
  }

  .strong-cell {
    font-weight: 600;
  }

  .muted-cell {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .user-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .status-chip {
    display: inline-flex;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .status-chip.active {
    background: #e7f6ef;
    color: #16543b;
  }

  .status-chip.invited {
    background: #fff8df;
    color: #7a5a00;
  }

  .status-chip.suspended {
    background: #fff0f2;
    color: #8f1730;
  }

  .danger-ghost {
    border-color: color-mix(in srgb, var(--danger) 50%, var(--line));
    color: var(--danger);
  }

  .form-actions {
    grid-column: 1 / -1;
  }

  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
</style>
