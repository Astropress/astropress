---
import AdminLayout from "@astropress-diy/astropress/components/AdminLayout.astro";
import AuditTrail from "@astropress-diy/astropress/components/AuditTrail.astro";
import { buildAdminDashboardPageModel } from "astropress";

const adminUser = Astro.locals.adminUser;
const model = await buildAdminDashboardPageModel(Astro.locals, adminUser?.role);
const {
	comments,
	redirectRules,
	routePages,
	posts,
	pages,
	reviewPosts,
	scheduledPosts,
	recentAuditEvents,
	recentActivity,
	translationNeedsAttention,
	supportSurfaceLinks,
	latestDeployment,
} = model.data;
const deploymentSucceeded = latestDeployment?.action === "deployment.trigger";
const deploymentLabel = !latestDeployment
	? "No publish recorded"
	: deploymentSucceeded
		? "Triggered"
		: "Failed";
---

<AdminLayout
  title="Dashboard"
  heading="Dashboard"
  currentPath="/ap-admin"
  description={adminUser?.role === "admin"
    ? "Editorial overview, page health, and admin queues."
    : "Editorial overview for blog posts, comments, and media work."}
  role={adminUser!.role}
  userName={adminUser!.name}
>
  {model.warnings.length > 0 && <p class="notice">Some dashboard data is temporarily unavailable. This page is showing partial results.</p>}
  <div class="stats-grid">
    <section class="panel stat stat-card">
      <span class="stat-label">Published posts</span>
      <strong>{posts.filter((record) => (record.status ?? "published") === "published").length}</strong>
      <p>Blog posts currently live on the public site.</p>
    </section>
    {adminUser?.role === "admin" ? (
      <section class="panel stat stat-card">
        <span class="stat-label">Public pages</span>
        <strong>{pages.length + routePages.length}</strong>
        <p>Legacy and route-backed public pages editable in admin.</p>
      </section>
    ) : (
      <section class="panel stat stat-card">
        <span class="stat-label">Pending comments</span>
        <strong>{comments.filter((comment) => comment.status === "pending").length}</strong>
        <p>Comments still waiting for moderation.</p>
      </section>
    )}
    <section class="panel stat stat-card">
      <span class="stat-label">Needs review</span>
      <strong>{reviewPosts.length}</strong>
      <p>Posts waiting for editorial attention.</p>
    </section>
    <section class="panel stat stat-card">
      <span class="stat-label">Scheduled posts</span>
      <strong>{scheduledPosts.length}</strong>
      <p>Upcoming blog posts with a future publish time.</p>
    </section>
    {adminUser?.role === "admin" && (
      <>
        <section class="panel stat stat-card">
          <span class="stat-label">Redirect rules</span>
          <strong>{redirectRules.length}</strong>
          <p>Active redirects currently managed in admin.</p>
        </section>
        <section class="panel stat stat-card">
          <span class="stat-label">Translation follow-up</span>
          <strong>{translationNeedsAttention}</strong>
          <p>Localized routes that still need attention before publication.</p>
        </section>
      </>
    )}
  </div>

  <div class="dashboard-layout">
    <section class="panel dashboard-panel action-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Create</p>
          <h2>Start New Work</h2>
          <p>Create new content quickly, then use the sidebar for the full editing surfaces.</p>
        </div>
      </div>
      <div class="action-grid compact">
        <a href="/ap-admin/posts/new" class="admin-button">New post</a>
        {adminUser?.role === "admin" && <a href="/ap-admin/pages/new" class="admin-button">New page</a>}
        {adminUser?.role === "admin" && <a href="/ap-admin/authors" class="admin-button-ghost">New author</a>}
        {adminUser?.role === "admin" && <a href="/ap-admin/users" class="admin-button-ghost">New user</a>}
      </div>
    </section>
    {adminUser?.role === "admin" && (
      <section class="panel dashboard-panel support-panel">
        <div class="section-header">
          <div>
            <h2>Support Surfaces</h2>
            <p>Metadata, route health, and system outputs.</p>
          </div>
        </div>
        <div class="support-grid">
          {supportSurfaceLinks.map((entry) => (
            <a href={entry.href} class="support-card">
              <strong>{entry.label}</strong>
              <span>{entry.count}</span>
              <small>{entry.helper}</small>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <div class="dashboard-columns">
    <section class="panel dashboard-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Queue</p>
          <h2>Scheduled Soon</h2>
          <p>The next posts queued to go live.</p>
        </div>
        <a href="/ap-admin/posts?workflow=scheduled" class="admin-button-ghost small">View scheduled</a>
      </div>
      {scheduledPosts.length > 0 ? (
        <ul class="queue-list">
          {scheduledPosts.map((record) => (
            <li>
              <div class="queue-copy">
                <strong>{record.title}</strong>
                <span>{record.scheduledAt ? new Date(record.scheduledAt).toLocaleString() : "Unscheduled"}</span>
              </div>
              <a href={`/ap-admin/posts/${record.slug}`} class="admin-button-ghost small">Open</a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-copy">No future scheduled posts are currently queued.</p>
      )}
    </section>
    <section class="panel dashboard-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Queue</p>
          <h2>{adminUser?.role === "admin" ? "Post Review Queue" : "Editorial Queue"}</h2>
          <p>Draft and review items waiting for an editor pass.</p>
        </div>
        <a href="/ap-admin/posts?workflow=review-needed" class="admin-button-ghost small">Open queue</a>
      </div>
      {reviewPosts.length > 0 ? (
        <ul class="queue-list">
          {reviewPosts.slice(0, 6).map((record) => (
            <li>
              <div class="queue-copy">
                <strong>{record.title}</strong>
                <span>{record.status ?? "published"}</span>
              </div>
              <a href={`/ap-admin/posts/${record.slug}`} class="admin-button-ghost small">Review</a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-copy">Nothing is currently waiting for editorial review.</p>
      )}
    </section>
    <section class="panel dashboard-panel wide-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Recent Activity</p>
          <h2>Recently Updated</h2>
          <p>Recent changes with direct editor entry points.</p>
        </div>
      </div>
      <ul class="queue-list">
        {recentActivity.map((record) => (
          <li>
            <div class="queue-copy">
              <strong>{record.title}</strong>
              <span>{record.kind} · {record.updatedAt ? new Date(record.updatedAt).toLocaleString() : "Unknown update time"}</span>
            </div>
            <a href={record.editHref} class="admin-button-ghost small">Open</a>
          </li>
        ))}
      </ul>
    </section>
  </div>

  {adminUser?.role === "admin" && (
    <section class="panel dashboard-panel deployment-panel">
      <div class="section-header">
        <div>
          <p class="admin-kicker">Publish</p>
          <h2>Latest Deployment</h2>
          <p>Trusted record of the most recent build trigger sourced from the audit log.</p>
        </div>
      </div>
      {latestDeployment ? (
        <div class={`deployment-status deployment-status--${deploymentSucceeded ? "ok" : "fail"}`}>
          <span class="deployment-badge">{deploymentLabel}</span>
          <div class="deployment-meta">
            <strong>{latestDeployment.summary}</strong>
            <span>
              {new Date(latestDeployment.createdAt).toLocaleString()} ·
              by {latestDeployment.actorEmail}
            </span>
          </div>
        </div>
      ) : (
        <p class="empty-copy">No publish has been triggered yet. Use the Publish button in the topbar to start a build.</p>
      )}
    </section>
  )}

  <AuditTrail events={recentAuditEvents} />
</AdminLayout>

<style>
  h2 {
    margin-top: 0;
    margin-bottom: 0.7rem;
    font-size: 1.05rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 0.85rem;
  }

  .dashboard-layout,
  .dashboard-columns {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .dashboard-layout {
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.9fr);
    align-items: start;
  }

  .dashboard-columns {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
  }

  .dashboard-panel {
    padding: 1.1rem;
  }

  .wide-panel {
    grid-column: 1 / -1;
  }

  .stat-card {
    gap: 0.4rem;
    align-items: flex-start;
  }

  .stat-label {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 700;
  }

  .stat-card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .stat-card strong {
    font-size: clamp(1.7rem, 2vw, 2.15rem);
    line-height: 1;
  }

  .action-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .action-grid.compact {
    gap: 0.65rem;
    align-items: center;
  }

  .action-grid.compact > a {
    min-width: 9rem;
    justify-content: center;
  }

  .queue-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.8rem;
  }

  .queue-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.8rem;
  }

  .queue-list li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .queue-copy {
    display: grid;
    gap: 0.2rem;
  }

  .queue-copy strong {
    font-size: 0.96rem;
  }

  .queue-copy span,
  .empty-copy {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .support-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .support-card {
    display: grid;
    gap: 0.28rem;
    padding: 0.95rem;
    border-radius: 0.95rem;
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--panel) 94%, var(--accent-soft) 6%);
    color: inherit;
    text-decoration: none;
  }

  .support-card span {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent);
  }

  .support-card small {
    color: var(--muted);
    line-height: 1.45;
  }

  .deployment-panel {
    margin-top: 1rem;
  }

  .deployment-status {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-radius: 0.7rem;
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--panel) 92%, transparent);
  }

  .deployment-status--ok {
    border-color: color-mix(in srgb, #16a34a 50%, var(--line));
    background: color-mix(in srgb, #16a34a 8%, var(--panel));
  }

  .deployment-status--fail {
    border-color: color-mix(in srgb, #dc2626 50%, var(--line));
    background: color-mix(in srgb, #dc2626 8%, var(--panel));
  }

  .deployment-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--panel);
    color: var(--muted);
  }

  .deployment-status--ok .deployment-badge {
    background: #16a34a;
    color: white;
  }

  .deployment-status--fail .deployment-badge {
    background: #dc2626;
    color: white;
  }

  .deployment-meta {
    display: grid;
    gap: 0.2rem;
  }

  .deployment-meta span {
    color: var(--muted);
    font-size: 0.85rem;
  }

  @media (max-width: 1100px) {
    .dashboard-layout,
    .dashboard-columns {
      grid-template-columns: 1fr;
    }

    .support-grid {
      grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    }
  }
</style>
