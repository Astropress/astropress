---
import { buildAcceptInvitePageModel, buildAstropressAdminDocumentTitle, resolveAstropressAdminUiConfig } from "astropress";

const token = Astro.url.searchParams.get("token") ?? "";
const hasError = Astro.url.searchParams.get("error") === "1";
const errorMessage = Astro.url.searchParams.get("message") ?? "That invitation link is invalid or has expired.";
const model = await buildAcceptInvitePageModel(Astro.locals, token);
const { inviteRequest } = model.data;
const adminUi = resolveAstropressAdminUiConfig();
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || t === 'light') {
            document.documentElement.setAttribute('data-theme', t);
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    {adminUi.branding.faviconHref && <link rel="icon" href={adminUi.branding.faviconHref} />}
    {adminUi.branding.stylesheetHref && <link rel="stylesheet" href={adminUi.branding.stylesheetHref} />}
    <title>{buildAstropressAdminDocumentTitle("Accept Invitation")}</title>
  </head>
  <body>
    <main class="login-shell">
      <section class="login-card">
        <div class="login-card-top">
          {adminUi.branding.logoSrc && <img src={adminUi.branding.logoSrc} alt={adminUi.branding.logoAlt} class="auth-logo" />}
          <p class="eyebrow">{adminUi.branding.appName}</p>
          <button
            type="button"
            class="theme-toggle-admin"
            id="auth-theme-toggle"
            aria-pressed="false"
            aria-label={adminUi.labels.themeToggleDark}
            title={adminUi.labels.themeToggleDark}
            data-theme-label-dark={adminUi.labels.themeToggleDark}
            data-theme-label-light={adminUi.labels.themeToggleLight}
          >
            <span class="theme-toggle-icon" aria-hidden="true"></span>
          </button>
        </div>
        <h1>{adminUi.labels.acceptInvitationHeading}</h1>
        <p>{adminUi.labels.acceptInvitationDescription}</p>

        {model.warnings.length > 0 && <p class="error">Invite-token validation is temporarily unavailable. This page is showing a safe fallback state.</p>}
        {hasError && <p class="error">{errorMessage}</p>}

        {inviteRequest ? (
          <>
            <p class="account-summary">
              Invited account for <strong>{inviteRequest.name}</strong> ({inviteRequest.email}).
            </p>
            <form method="post" action="/wp-admin/actions/accept-invite">
              <input type="hidden" name="token" value={token} />
              <label>
                <span>New password</span>
                <input type="password" name="password" autocomplete="new-password" minlength="12" required />
              </label>
              <label>
                <span>Confirm new password</span>
                <input type="password" name="confirmPassword" autocomplete="new-password" minlength="12" required />
              </label>
                <button type="submit">{adminUi.labels.acceptInvitationSubmit}</button>
              </form>
            </>
          ) : (
            <p class="error">That invitation link is invalid or has expired.</p>
          )}

        <p class="aux-link"><a href="/wp-admin/login">{adminUi.labels.backToLogin}</a></p>
      </section>
    </main>
    <script is:inline>
      (function() {
        var root = document.documentElement;
        var toggle = document.getElementById('auth-theme-toggle');
        if (!toggle) return;

        function applyTheme(theme) {
          var darkLabel = toggle.getAttribute('data-theme-label-dark') || 'Switch to dark mode';
          var lightLabel = toggle.getAttribute('data-theme-label-light') || 'Switch to light mode';
          root.setAttribute('data-theme', theme);
          toggle.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
          toggle.setAttribute('aria-label', theme === 'dark' ? lightLabel : darkLabel);
          toggle.setAttribute('title', theme === 'dark' ? lightLabel : darkLabel);
          toggle.querySelector('.theme-toggle-icon').textContent = theme === 'dark' ? '☀' : '☾';
        }

        function currentTheme() {
          return root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        }

        applyTheme(currentTheme());
        toggle.addEventListener('click', function() {
          var next = currentTheme() === 'dark' ? 'light' : 'dark';
          applyTheme(next);
          try {
            localStorage.setItem('theme', next);
          } catch (e) {}
        });
      })();
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #eff4f7;
    --card: #fffefb;
    --text: #1d2733;
    --accent: #0d5c63;
    --line: #d8dee5;
    --error: #a11f36;
    --surface-glow: radial-gradient(circle at top, #dceef0 0%, var(--bg) 48%, #edf1e8 100%);
  }

  html[data-theme="dark"] {
    color-scheme: dark;
    --bg: #101815;
    --card: #18231f;
    --text: #edf4ef;
    --accent: #8fd0a0;
    --line: #31433b;
    --error: #ff9bb0;
    --surface-glow: radial-gradient(circle at top, #203429 0%, #101815 48%, #17211d 100%);
  }

  html {
    font-family: "Trebuchet MS", "Segoe UI", sans-serif;
    background: var(--surface-glow);
    color: var(--text);
  }

  body {
    margin: 0;
  }

  .login-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 1.5rem;
  }

  .login-card {
    position: relative;
    width: min(100%, 32rem);
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    padding: 1.5rem;
    box-shadow: 0 20px 60px rgba(17, 30, 42, 0.08);
  }

  html[data-theme="dark"] .login-card {
    box-shadow: 0 22px 70px rgba(0, 0, 0, 0.34);
  }

  .login-card-top {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1rem;
    margin-bottom: 0.35rem;
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent);
  }

  .auth-logo {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
    border-radius: 0.35rem;
  }

  .theme-toggle-admin {
    position: absolute;
    top: 1.1rem;
    right: 1.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: transparent;
    color: var(--text);
    cursor: pointer;
  }

  .theme-toggle-icon {
    font-size: 1.35rem;
    line-height: 1;
  }

  h1 {
    margin: 0 0 0.5rem;
  }

  form {
    display: grid;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  label {
    display: grid;
    gap: 0.4rem;
  }

  input {
    border: 1px solid var(--line);
    border-radius: 0.7rem;
    padding: 0.8rem 0.9rem;
    font: inherit;
    background: var(--card);
    color: var(--text);
  }

  button {
    border: 0;
    border-radius: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--accent);
    color: white;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .error {
    color: var(--error);
    font-weight: 700;
  }

  .account-summary {
    margin: 1rem 0 0;
    color: var(--text);
  }

  .aux-link {
    margin: 1rem 0 0;
    font-size: 0.95rem;
  }

  .aux-link a {
    color: var(--accent);
    font-weight: 600;
  }
</style>
