{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@astropress-diy/astropress": ["./index.ts"],
      "@astropress-diy/astropress/components/*": ["./components/*"],
      "@astropress-diy/astropress/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "index.ts", "components/**/*", "bin/**/*"]
}
