---
import { buildAstropressAdminDocumentTitle } from "../src/admin-branding";
import { applyAstropressSecurityHeaders } from "../src/security-headers";
import { resolveAstropressAdminUiConfig } from "../src/admin-ui";
import { getAdminBootstrapConfig } from "../src/runtime-env";
import { peekCmsConfig } from "../src/config";
import { getRecentAdminItems } from "../src/admin-recent";

interface NavItem {
  href?: string;
  label: string;
  adminOnly?: boolean;
  isGroupLabel?: boolean;
  indent?: boolean;
}

interface Props {
  title: string;
  heading: string;
  currentPath: string;
  description?: string;
  role: "admin" | "editor";
  userName: string;
  siteName?: string;
  /** When true, shows the CMS nav item linking to /ap-admin/cms. */
  hasCms?: boolean;
  /** When true, shows the Host nav item (admin-only) linking to /ap-admin/host. */
  hasHostPanel?: boolean;
  /** When true, shows the Publish button in the topbar (admin-only). */
  canPublish?: boolean;
}

const { title, heading, currentPath, description = "", role, userName, siteName, hasCms = false, hasHostPanel = false, canPublish = false } = Astro.props;
const documentTitle = buildAstropressAdminDocumentTitle(title);
const adminUi = resolveAstropressAdminUiConfig();
const adminSiteName = siteName ?? adminUi.branding.shellName;
const { bootstrapDisabled } = getAdminBootstrapConfig(Astro.locals);
applyAstropressSecurityHeaders(Astro.response.headers, { area: "admin", allowInlineStyles: true, forceHsts: Astro.url.protocol === "https:" });
const hasFundraising = !!(peekCmsConfig()?.donations);
const hasTestimonials = !!(peekCmsConfig()?.testimonials);
const recentItems = await getRecentAdminItems(Astro.locals, role);

const pluginNavItems: NavItem[] = (peekCmsConfig()?.plugins ?? [])
  .flatMap((p) => p.navItems ?? [])
  .map((item) => ({ href: item.href, label: item.label }));

const navItems: NavItem[] = [
  { href: "/ap-admin", label: adminUi.navigation.dashboard },
  { href: "", label: adminUi.navigation.contentGroup, isGroupLabel: true },
  { href: "/ap-admin/pages", label: adminUi.navigation.pages, adminOnly: true, indent: true },
  { href: "/ap-admin/posts", label: adminUi.navigation.posts, indent: true },
  { href: "/ap-admin/authors", label: adminUi.navigation.authors, adminOnly: true, indent: true },
  { href: "/ap-admin/taxonomies", label: adminUi.navigation.taxonomies, adminOnly: true, indent: true },
  { href: "/ap-admin/route-pages", label: adminUi.navigation.routePages, adminOnly: true, indent: true },
  { href: "/ap-admin/archives", label: adminUi.navigation.archives, adminOnly: true, indent: true },
  { href: "/ap-admin/users", label: adminUi.navigation.users, adminOnly: true, indent: true },
  { href: "/ap-admin/media", label: adminUi.navigation.media },
  { href: "/ap-admin/comments", label: adminUi.navigation.comments },
  { href: "/ap-admin/redirects", label: adminUi.navigation.redirects, adminOnly: true },
  { href: "/ap-admin/translations", label: adminUi.navigation.translations, adminOnly: true },
  { href: "/ap-admin/seo", label: adminUi.navigation.seo, adminOnly: true },
  { href: "/ap-admin/system", label: adminUi.navigation.system, adminOnly: true },
  { href: "/ap-admin/settings", label: adminUi.navigation.settings, adminOnly: true },
  { href: "/ap-admin/services", label: adminUi.navigation.services, adminOnly: true },
  ...(hasFundraising ? [{ href: "/ap-admin/fundraising", label: adminUi.navigation.fundraising, adminOnly: true as const }] : []),
  ...(hasTestimonials ? [{ href: "/ap-admin/testimonials", label: adminUi.navigation.testimonials, adminOnly: true as const }] : []),
  ...(hasCms ? [{ href: "/ap-admin/cms", label: adminUi.navigation.cms }] : []),
  ...(hasHostPanel ? [{ href: "/ap-admin/host", label: adminUi.navigation.host, adminOnly: true as const }] : []),
  ...pluginNavItems,
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    {adminUi.branding.faviconHref && <link rel="icon" href={adminUi.branding.faviconHref} />}
    <link rel="stylesheet" href="/admin.css" />
    {adminUi.branding.stylesheetHref && <link rel="stylesheet" href={adminUi.branding.stylesheetHref} />}
    <title>{documentTitle}</title>
    <meta name="description" content={description || documentTitle} />
  </head>
  <body>
    <a class="skip-link" href="#admin-main">Skip to admin content</a>
    <header class="topbar">
      <a class="topbar-brand" href={adminUi.branding.logoHref}>
        {adminUi.branding.logoSrc ? (
          <img src={adminUi.branding.logoSrc} alt={adminUi.branding.logoAlt} class="topbar-logo" />
        ) : null}
        <strong>{adminSiteName}</strong>
      </a>
      <div class="topbar-meta">
        {canPublish && role === "admin" && (
          <form method="post" action="/ap-admin/actions/publish" class="publish-form">
            <button type="submit" class="publish-btn" title="Trigger a new production build">
              Publish
            </button>
          </form>
        )}
        <button
          type="button"
          class="nav-toggle"
          data-nav-toggle
          aria-label="Open navigation"
          aria-expanded="false"
          aria-controls="admin-sidebar"
          data-label-open="Open navigation"
          data-label-close="Close navigation"
        >
          <span aria-hidden="true">☰</span>
        </button>
        <span>{adminUi.labels.signedInAsPrefix} {userName}</span>
        <span class="role-chip">{role}</span>
        <ap-theme-toggle label-dark={adminUi.labels.themeToggleDark} label-light={adminUi.labels.themeToggleLight}>
          <button
            type="button"
            class="theme-toggle-admin"
            id="admin-theme-toggle"
            aria-pressed="false"
            aria-label={adminUi.labels.themeToggleDark}
            title={adminUi.labels.themeToggleDark}
          >
            <span class="theme-toggle-icon" aria-hidden="true"></span>
          </button>
        </ap-theme-toggle>
        <select
          class="locale-select"
          aria-label={adminUi.labels.changeLanguage}
          title={adminUi.labels.changeLanguage}
          data-locale-select
        >
          <option value="en">English</option>
          <option value="es">Español</option>
          <option value="fr">Français</option>
          <option value="de">Deutsch</option>
          <option value="pt">Português</option>
          <option value="ja">日本語</option>
        </select>
        <script>
          {`(function () {
            var sel = document.querySelector('[data-locale-select]');
            if (!sel) return;
            var stored = localStorage.getItem('ap-admin-locale') || 'en';
            sel.value = stored;
            document.documentElement.lang = stored;
            sel.addEventListener('change', function () {
              localStorage.setItem('ap-admin-locale', sel.value);
              document.documentElement.lang = sel.value;
            });
          })();`}
        </script>
        <button
          type="button"
          class="help-popover-trigger"
          popovertarget="admin-keyboard-shortcuts"
          aria-label="Keyboard shortcuts"
          title="Keyboard shortcuts"
        >
          <span aria-hidden="true">?</span>
        </button>
        <div
          id="admin-keyboard-shortcuts"
          popover
          class="keyboard-shortcuts-popover"
          role="dialog"
          aria-label="Keyboard shortcuts"
        >
          <h2>Keyboard shortcuts</h2>
          <table>
            <tbody>
              <tr><td><kbd>Ctrl</kbd>+<kbd>S</kbd></td><td>Save draft</td></tr>
              <tr><td><kbd>Ctrl</kbd>+<kbd>Enter</kbd></td><td>Publish / submit form</td></tr>
              <tr><td><kbd>Escape</kbd></td><td>Close dialog or panel</td></tr>
              <tr><td><kbd>Tab</kbd></td><td>Move to next field</td></tr>
              <tr><td><kbd>Shift</kbd>+<kbd>Tab</kbd></td><td>Move to previous field</td></tr>
              <tr><td><kbd>?</kbd></td><td>Show this help panel</td></tr>
              <tr><td><kbd>Ctrl</kbd>+<kbd>K</kbd></td><td>Open command palette</td></tr>
            </tbody>
          </table>
        </div>
        <form method="post" action="/ap-admin/session?logout=1">
          <button type="submit">{adminUi.labels.signOut}</button>
        </form>
      </div>
    </header>
    <ap-admin-nav>
    <div class="admin-shell">
      <nav id="admin-sidebar" class="sidebar" data-nav-sidebar aria-label="Admin sections">
        <button
          type="button"
          class="nav-close"
          data-nav-close
          aria-label="Close navigation"
        >
          <span aria-hidden="true">✕</span>
        </button>
        <p class="sidebar-label">{adminUi.labels.sidebarTitle}</p>
        {navItems
          .filter((item) => (item.adminOnly ? role === "admin" : true))
          .map((item) => {
            if (item.isGroupLabel) {
              return <p class="sidebar-group-label">{item.label}</p>;
            }
            return (
              <a
                href={item.href}
                aria-current={currentPath === item.href ? "page" : undefined}
                class={item.indent ? "sidebar-child" : ""}
              >
                {item.label}
              </a>
            );
          })}
        {recentItems.length > 0 && (
          <>
            <p class="sidebar-group-label">Recent</p>
            {recentItems.map((item) => (
              <a
                href={item.editHref}
                class="sidebar-child sidebar-recent-item"
                title={item.title}
              >
                {item.title.length > 28 ? item.title.slice(0, 26) + "\u2026" : item.title}
              </a>
            ))}
          </>
        )}
      </nav>
      <main id="admin-main" tabindex="-1">
        <section class="page-header">
          <h1>{heading}</h1>
          {description && <p>{description}</p>}
        </section>
        {!bootstrapDisabled && (
          <ap-notice type="info">
            You're using default bootstrap credentials — <a href="/ap-admin/settings">change your password</a> before deploying to a live server.
          </ap-notice>
        )}
        <div
          role="alert"
          aria-live="assertive"
          aria-atomic="true"
          data-action-error
          class="action-error-region"
        ></div>
        <slot />
      </main>
    </div>
    </ap-admin-nav>
    <footer class="ap-admin-footer">
      <a
        href="https://github.com/Astropress/astropress/issues"
        target="_blank"
        rel="noopener noreferrer"
        class="ap-admin-footer__link"
      >Report an issue</a>
      <span class="ap-admin-footer__sep" aria-hidden="true">·</span>
      <a
        href="https://github.com/Astropress/astropress"
        target="_blank"
        rel="noopener noreferrer"
        class="ap-admin-footer__link"
      >Astropress</a>
    </footer>
    <ap-command-palette data-nav-items={JSON.stringify(navItems.filter((n) => n.href && !n.isGroupLabel).map((n) => ({ label: n.label, href: n.href })))}>
      <dialog id="cmd-palette" class="cmd-palette" aria-label="Command palette">
        <input type="search" class="cmd-input" placeholder="Go to\u2026" aria-label="Search admin pages" autocomplete="off" />
        <ul class="cmd-results" role="listbox" aria-label="Command palette results" aria-live="polite"></ul>
      </dialog>
    </ap-command-palette>
    <script>
      import "../web-components/theme-toggle";
      import "../web-components/admin-nav";
      import "../web-components/notice";
      import "../web-components/command-palette";
    </script>
    <script>
      // Progressive enhancement: inline form validation with custom messages.
      // Degrades gracefully when JS is unavailable — browser native validation still applies.
      (function () {
        function getCustomMessage(input: HTMLInputElement): string {
          if (!input.validity.valid) {
            if (input.dataset.errorRequired && input.validity.valueMissing) return input.dataset.errorRequired;
            if (input.dataset.errorPattern && input.validity.patternMismatch) return input.dataset.errorPattern;
            if (input.dataset.errorMinlength && input.validity.tooShort) return input.dataset.errorMinlength;
            if (input.dataset.errorType && (input.validity.typeMismatch || input.validity.badInput)) return input.dataset.errorType;
          }
          return input.validationMessage;
        }

        function showError(input: HTMLInputElement): void {
          const describedBy = input.getAttribute("aria-describedby");
          let errorEl = describedBy ? document.getElementById(describedBy) : null;
          if (!errorEl) {
            const id = `field-error-${Math.random().toString(36).slice(2)}`;
            errorEl = document.createElement("span");
            errorEl.id = id;
            errorEl.className = "field-error";
            errorEl.setAttribute("aria-live", "polite");
            input.insertAdjacentElement("afterend", errorEl);
            input.setAttribute("aria-describedby", id);
          }
          const msg = getCustomMessage(input);
          errorEl.textContent = msg;
          input.setAttribute("aria-invalid", msg ? "true" : "false");
        }

        function clearError(input: HTMLInputElement): void {
          input.setCustomValidity("");
          const id = input.getAttribute("aria-describedby");
          const errorEl = id ? document.getElementById(id) : null;
          if (errorEl) errorEl.textContent = "";
          input.setAttribute("aria-invalid", "false");
        }

        document.addEventListener("invalid", (e) => {
          const input = e.target as HTMLInputElement;
          if (!(input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement || input instanceof HTMLSelectElement)) return;
          e.preventDefault();
          showError(input as HTMLInputElement);
        }, true);

        document.addEventListener("input", (e) => {
          const input = e.target as HTMLInputElement;
          if (!(input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement)) return;
          if (input.getAttribute("aria-invalid") === "true") clearError(input as HTMLInputElement);
        });

        // Restore session-storage error messages (set by server actions to keep sensitive names out of URL history).
        const storedError = sessionStorage.getItem("ap_action_error");
        if (storedError) {
          sessionStorage.removeItem("ap_action_error");
          const liveRegion = document.querySelector<HTMLElement>("[aria-live='assertive'][data-action-error]");
          if (liveRegion) liveRegion.textContent = storedError;
        }

        // Optimistic publish button — disable and relabel on submit; page navigation completes naturally.
        document.querySelector(".publish-form")?.addEventListener("submit", (e) => {
          const btn = (e.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>(".publish-btn");
          if (btn) { btn.textContent = "Publishing\u2026"; btn.disabled = true; }
        });
      })();
    </script>
  <style>
    .ap-admin-footer {
      padding: 0.5rem 1.5rem;
      font-size: 0.75rem;
      color: var(--color-text-muted, #6b7280);
      border-top: 1px solid var(--color-border, #e5e7eb);
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }
    .ap-admin-footer__link {
      color: inherit;
      text-decoration: none;
    }
    .ap-admin-footer__link:hover {
      text-decoration: underline;
    }
    .ap-admin-footer__sep {
      color: var(--color-text-muted, #6b7280);
    }
  </style>
  </body>
</html>
