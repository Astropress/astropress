---
/**
 * AstropressFaqJsonLd.astro
 *
 * Emits a JSON-LD FAQPage schema (schema.org/FAQPage) for content with Q&A pairs.
 * Place this inside <head> in your post/page layout when the page contains FAQ content.
 *
 * Usage:
 *   <AstropressFaqJsonLd
 *     items={[
 *       { question: "What is Astropress?", answer: "A web app framework built on Astro." },
 *       { question: "Does it support Cloudflare?", answer: "Yes — D1, R2, and Workers." },
 *     ]}
 *   />
 *
 * AI answer engines (Google AI Overviews, Perplexity, Bing Copilot) preferentially
 * cite pages with FAQPage structured data when answering question-style queries.
 */

export interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const json = JSON.stringify(jsonLd).replace(/<\/(script)/gi, "<\\/$1").replace(/<(script)/gi, "<$1");
---

<script type="application/ld+json" set:html={json}></script>
