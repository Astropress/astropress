    "./cloudflare-vite-integration": "./src/cloudflare-vite-integration.ts",
    "./vite-integration": "./src/vite-integration.ts",
    "./vite-runtime-alias": "./src/vite-runtime-alias.ts",
    "./vitest-runtime-alias": "./src/vitest-runtime-alias.ts",
    "./host-runtime-modules": "./src/host-runtime-modules.ts",
    "./host-runtime-factories": "./src/host-runtime-factories.ts",
    "./admin-store-adapter-factory": "./src/admin-store-adapter-factory.ts",
    "./auth-repository-factory": "./src/auth-repository-factory.ts",
    "./content-repository-factory": "./src/content-repository-factory.ts",
    "./cms-route-registry-factory": "./src/cms-route-registry-factory.ts",
    "./local-media-repository-factory": "./src/local-media-repository-factory.ts",
    "./redirect-repository-factory": "./src/redirect-repository-factory.ts",
    "./taxonomy-repository-factory": "./src/taxonomy-repository-factory.ts",
