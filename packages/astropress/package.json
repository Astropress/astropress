  "files": [
    "bin",
    "components",
    "index.ts",
    "pages",
    "src",
    "web-components"
  ],
  "peerDependencies": {
    "astro": ">=6.0.0",
    "zod": ">=4.0.0"
  },
  "dependencies": {
    "htmlparser2": "^9.1.0",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "schema-dts": "^2.0.0",
    "typescript": "5.9.3",
    "vitest": "^3"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json --noCheck && bun ../../scripts/add-js-ext.ts src",
    "release": "changeset publish",
    "version": "changeset version",
    "prepublishOnly": "bun run build && cd ../.. && bun run audit:sync && bun run audit:arch"
  },
  "keywords": [
    "astro",
    "web-app-framework",
    "wordpress-migration",
    "cloudflare",
    "supabase",
    "runway",
    "github-pages",
    "web-components"
  ],
  "sideEffects": [
    "./web-components/*.ts",
    "./web-components/*.js",
    "./web-components/index.ts"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/astropress/astropress"
  },
  "bugs": {
    "url": "https://github.com/astropress/astropress/issues"
  },
  "homepage": "https://github.com/astropress/astropress#readme"
}
