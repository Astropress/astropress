    "./web-components/admin-nav": "./web-components/admin-nav.ts",
    "./web-components/notice": "./web-components/notice.ts",
    "./web-components/theme-toggle": "./web-components/theme-toggle.ts",
    "./web-components/confirm-dialog": "./web-components/confirm-dialog.ts",
    "./web-components/html-editor": "./web-components/html-editor.ts",
    "./web-components/ap-stale-tab-warning": "./web-components/ap-stale-tab-warning.ts",
    "./api-middleware": "./src/api-middleware.ts",
