    "./hosted-api-adapter": "./src/hosted-api-adapter.ts",
    "./hosted-platform-adapter": "./src/hosted-platform-adapter.ts",
    "./provider-targets": "./src/provider-targets.ts",
    "./sqlite-bootstrap": "./src/sqlite-bootstrap.ts",
