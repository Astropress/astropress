{
  "name": "astropress",
  "version": "0.1.0",
  "description": "Low-carbon, provider-neutral Astro CMS toolkit for migrations from WordPress and new editorial sites.",
  "type": "module",
  "bin": {
    "astropress": "./bin/astropress.js"
  },
  "exports": {
    ".": "./index.ts",
    "./components/*": "./components/*.astro",
    "./platform-contracts": "./src/platform-contracts.ts",
    "./provider-targets": "./src/provider-targets.ts",
    "./integration": "./src/integration.js",
    "./cloudflare-vite-integration": "./src/cloudflare-vite-integration.js",
    "./vite-integration": "./src/vite-integration.js",
    "./vite-runtime-alias": "./src/vite-runtime-alias.js",
    "./vitest-runtime-alias": "./src/vitest-runtime-alias.js",
    "./host-runtime-modules": "./src/host-runtime-modules.js",
    "./host-runtime-factories": "./src/host-runtime-factories.js",
    "./admin-store-adapter-factory": "./src/admin-store-adapter-factory.js",
    "./local-media-repository-factory": "./src/local-media-repository-factory.js",
    "./redirect-repository-factory": "./src/redirect-repository-factory.js",
    "./taxonomy-repository-factory": "./src/taxonomy-repository-factory.js",
    "./author-repository-factory": "./src/author-repository-factory.js",
    "./local-runtime-modules": "./src/local-runtime-modules.ts",
    "./cloudflare-workers-stub": "./src/cloudflare-workers-stub.ts",
    "./cloudflare-local-runtime-stubs": "./src/cloudflare-local-runtime-stubs.ts",
    "./cloudflare-local-image-storage-stub": "./src/cloudflare-local-image-storage-stub.js",
    "./cloudflare-local-media-storage-stub": "./src/cloudflare-local-media-storage-stub.js",
    "./admin-dashboard": "./src/admin-dashboard.ts",
    "./admin-page-models": "./src/admin-page-models.ts",
    "./runtime-page-store": "./src/runtime-page-store.ts",
    "./runtime-admin-actions": "./src/runtime-admin-actions.ts",
    "./runtime-admin-auth": "./src/runtime-admin-auth.ts",
    "./runtime-route-registry": "./src/runtime-route-registry.ts",
    "./runtime-env": "./src/runtime-env.ts",
    "./runtime-media-storage": "./src/runtime-media-storage.ts",
    "./media": "./src/media.ts",
    "./site-settings": "./src/site-settings.ts",
    "./seeded-content-type": "./src/seeded-content-type.ts",
    "./transactional-email": "./src/transactional-email.ts",
    "./newsletter-adapter": "./src/newsletter-adapter.ts",
    "./turnstile": "./src/turnstile.ts",
    "./local-image-storage": "./src/local-image-storage.js",
    "./local-media-storage": "./src/local-media-storage.js"
  },
  "files": [
    "bin",
    "components",
    "index.ts",
    "src"
  ],
  "peerDependencies": {
    "astro": ">=6.0.0",
    "zod": ">=4.0.0"
  },
  "dependencies": {
    "htmlparser2": "^9.1.0",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vitest": "^3"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "astro",
    "cms",
    "wordpress-migration",
    "cloudflare",
    "supabase",
    "runway",
    "github-pages"
  ],
  "license": "MIT"
}
