    "./comment-repository-factory": "./src/comment-repository-factory.ts",
    "./submission-repository-factory": "./src/submission-repository-factory.ts",
    "./user-repository-factory": "./src/user-repository-factory.ts",
    "./settings-repository-factory": "./src/settings-repository-factory.ts",
    "./translation-repository-factory": "./src/translation-repository-factory.ts",
    "./rate-limit-repository-factory": "./src/rate-limit-repository-factory.ts",
