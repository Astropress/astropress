{
  "name": "@astropress-diy/nexus",
  "version": "0.0.3",
  "description": "Multi-site gateway for Astropress — a single control plane over multiple Astropress sites",
  "type": "module",
  "bin": {
    "astropress-nexus": "./dist/server.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "prepublishOnly": "bun run build",
    "start": "node dist/server.js",
    "dev": "bun run src/server.ts",
    "test": "bunx vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=24.8.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Astropress/astropress"
  },
  "bugs": {
    "url": "https://github.com/Astropress/astropress/issues"
  },
  "homepage": "https://astropress.diy"
}
